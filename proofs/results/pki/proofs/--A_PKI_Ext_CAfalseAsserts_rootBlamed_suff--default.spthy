             = sign(<$CA.93, $id.96, pkID.103, 'pubKey', sn.106, $i.94, $j.97>, x.184)
       sn    = sn.106
       snCA  = snCA.107
       z     = true
       z.1   = verify(ca_sig.101,
                      <$rootCA.100, $CA.93, pk(x.184), 'pubKey-CA', snCA.107, $i0.95, $j0.98>,
                      pkRootCA.104)
    
    3. $CA   = $CA.94
