                     <fields, ca_fields>
         ) @ #t0) ∧
        (AssertsNot( rootCA, 'I signed this intermediate CA.', CA, ca_fields
         ) @ #t1)) ∨
      (∃ CA rootCA fields ca_fields #t0 #t1.
