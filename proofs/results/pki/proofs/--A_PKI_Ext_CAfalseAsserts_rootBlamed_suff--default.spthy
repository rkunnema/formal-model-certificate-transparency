       z     = true
       z.1   = true
  */

restriction rootCA_CA_distinct:
  "∀ rootCA CA #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (NonRoot_CA_Init( CA ) @ #t2)) ⇒
    (¬(rootCA = CA))"
  // safety formula

restriction CAsUnique:
  "∀ CA pk1 sk1 pk2 sk2 #t1 #t2.
    ((CA_Registered( CA, sk1, pk1 ) @ #t1) ∧
     (CA_Registered( CA, sk2, pk2 ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction eq:
  "∀ e1 e2 #t. (Eq( e1, e2 ) @ #t) ⇒ (e1 = e2)"
  // safety formula

restriction time_monotonicity:
  "∀ t #t1 #t3.
    (((Time( t ) @ #t1) ∧ (Time( t ) @ #t3)) ∧ (#t1 < #t3)) ⇒
    (∀ tp #t2.
      (((Time( tp ) @ #t2) ∧ (#t1 < #t2)) ∧ (#t2 < #t3)) ⇒ (tp = t))"
  // safety formula

restriction certStillValid:
  "∀ currTime valid_till #t1.
    ((Time( currTime ) @ #t1) ∧
     (CheckValidUntil( currTime, valid_till ) @ #t1)) ⇒
    (¬(∃ #t2. (#t2 < #t1) ∧ (Time( valid_till ) @ #t2)))"
  // safety formula

rule (modulo E) compromiseCA[color=#d40808]:
   [ !CA_s0( $CA, ~skCA, pk(~skCA), ca_fields, CA_sig ) ]
  --[
  CompromiseCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseCA( ), Time( $now )
  ]->
   [ Out( ~skCA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseRootCA[color=#d40808]:
   [ !Root_CA_s0( $CA, skCA, pkCA ) ]
  --[
  CompromiseRootCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseRootCA( ), Time( $now )
  ]->
   [ Out( skCA ) ]

  /* has exactly the trivial AC variant */

lemma san_Root_CA_Init:
  exists-trace
  "∃ #t. (San_Root_CA_Init( ) @ #t) ∧ (¬(∃ #t.1. Compromise( ) @ #t.1))"
/*
guarded formula characterizing all satisfying traces:
"∃ #t. (San_Root_CA_Init( ) @ #t) ∧ ∀ #t.1. (Compromise( ) @ #t.1) ⇒ ⊥"
*/
by sorry

