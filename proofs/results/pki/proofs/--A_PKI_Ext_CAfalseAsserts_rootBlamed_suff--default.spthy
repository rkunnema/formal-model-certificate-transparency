lemma CA_auth_w_compromise:
  exists-trace
  "∃ L1 L2 rootCA ca_fields CA fields #t.
    (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #t) ∧
    (¬(∃ #t1. CAAsserts( CA, fields ) @ #t1))"
/*
guarded formula characterizing all satisfying traces:
"∃ L1 L2 rootCA ca_fields CA fields #t.
  (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #t)
 ∧
  ∀ #t1. (CAAsserts( CA, fields ) @ #t1) ⇒ ⊥"
*/
by sorry

lemma authenticity:
  all-traces
  "∀ L1 L2 rootCA ca_fields CA fields #j.
    (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #j) ⇒
    (∃ #i. (GroundTruth( CA, fields ) @ #i) ∧ (#i < #j))"
/*
guarded formula characterizing all counter-examples:
"∃ L1 L2 rootCA ca_fields CA fields #j.
  (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #j)
 ∧
  ∀ #i. (GroundTruth( CA, fields ) @ #i) ⇒ ¬(#i < #j)"
*/
by sorry

lemma cert_auth:
  all-traces
  "∀ L1 L2 rootCA ca_fields CA fields #t.
    (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #t) ⇒
    (((∃ #t1. CAAsserts( CA, fields ) @ #t1) ∨
      (∃ #t2. (CompromiseCA( CA ) @ #t2) ∧ (#t2 < #t))) ∨
     (∃ #t2. (CompromiseRootCA( rootCA ) @ #t2) ∧ (#t2 < #t)))"
/*
guarded formula characterizing all counter-examples:
"∃ L1 L2 rootCA ca_fields CA fields #t.
  (ClientAcceptsChain( L1, L2, rootCA, ca_fields, CA, fields ) @ #t)
 ∧
  (∀ #t1. (CAAsserts( CA, fields ) @ #t1) ⇒ ⊥) ∧
  (∀ #t2. (CompromiseCA( CA ) @ #t2) ⇒ ¬(#t2 < #t)) ∧
  (∀ #t2. (CompromiseRootCA( rootCA ) @ #t2) ⇒ ¬(#t2 < #t))"
*/
by sorry

lemma A_PKI_Ext_CAfalseAsserts_rootBlamed_suff:
  exists-trace
  "∃ rootCA CA fields ca_fields #t0 #t1.
    (((AssertsNot( 'external auditor', 'this is a correct statement', CA,
                   <fields, ca_fields>
       ) @ #t0) ∧
      (AssertsNot( rootCA, 'I signed this intermediate CA.', CA, ca_fields
       ) @ #t1)) ∧
     (∀ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1.
       ((AssertsNot( 'external auditor', 'this is a correct statement', CA.1,
                     <fields.1, ca_fields.1>
         ) @ #t0.1) ∧
        (AssertsNot( rootCA.1, 'I signed this intermediate CA.', CA.1,
                     ca_fields.1
         ) @ #t1.1)) ⇒
       (rootCA.1 = rootCA))) ∧
    ((∀ a #i. (Corrupted( a ) @ #i) ⇒ (a = rootCA)) ∧
     (¬(∃ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1.
         (AssertsNot( 'external auditor', 'this is a correct statement', CA.1,
                      <fields.1, ca_fields.1>
          ) @ #t0.1) ∧
         (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
          ) @ #t1.1))))"
/*
guarded formula characterizing all satisfying traces:
"∃ rootCA CA fields ca_fields #t0 #t1.
  (AssertsNot( 'external auditor', 'this is a correct statement', CA,
               <fields, ca_fields>
   ) @ #t0) ∧
  (AssertsNot( rootCA, 'I signed this intermediate CA.', CA, ca_fields
   ) @ #t1)
 ∧
  (∀ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1.
    (AssertsNot( 'external auditor', 'this is a correct statement', CA.1,
                 <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (AssertsNot( rootCA.1, 'I signed this intermediate CA.', CA.1,
                 ca_fields.1
     ) @ #t1.1)
   ⇒
    rootCA.1 = rootCA) ∧
  (∀ a #i. (Corrupted( a ) @ #i) ⇒ a = rootCA) ∧
  (∀ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1.
    (AssertsNot( 'external auditor', 'this is a correct statement', CA.1,
                 <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
     ) @ #t1.1)
   ⇒
    ⊥)"
*/
simplify
solve( AssertsNot( 'external auditor', 'this is a correct statement', CA,
                   <fields, ca_fields>
       ) @ #t0 )
  case external_check_false
  solve( !Root_CA( $rootCA, pk(x.1) ) ▶₄ #t0 )
    case Root_CA_Init
    solve( AssertsNot( rootCA.1, 'I signed this intermediate CA.', $CA,
                       <$rootCA, $CA, pk(x), 'pubKey-CA', snCA, $i0, $j0>
           ) @ #t1 )
      case ConsultDocumentation_Fails
      solve( !Root_CA( $rootCA, pk(x.1) ) ▶₂ #t1 )
        case Root_CA_Init
        solve( !KU( sign(<$rootCA, $CA, pk(x), 'pubKey-CA', snCA, $i0, $j0>,
                         ~skCA)
               ) @ #vk.26 )
          case c_sign
          solve( !KU( ~skCA ) @ #vk.27 )
            case compromiseRootCA
            solve( !KU( sign(<$CA, $id, pkID, 'pubKey', sn, $i, $j>, x) ) @ #vk.17 )
              case c_sign
              solve( !KU( pk(x) ) @ #vk.20 )
                case Root_CA_Init_case_1
                solve( !KU( ~skCA ) @ #vk.28 )
                  case compromiseRootCA
                  SOLVED // trace found
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

