lemma cert_auth:
  all-traces
  "∀ rootCA ca_fields CA fields #t.
    (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t) ⇒
    (((∃ #t1. CAAsserts( CA, fields ) @ #t1) ∨
      (∃ #t2. (CompromiseCA( CA ) @ #t2) ∧ (#t2 < #t))) ∨
     (∃ #t2. (CompromiseRootCA( rootCA ) @ #t2) ∧ (#t2 < #t)))"
/*
guarded formula characterizing all counter-examples:
"∃ rootCA ca_fields CA fields #t.
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t)
 ∧
  (∀ #t1. (CAAsserts( CA, fields ) @ #t1) ⇒ ⊥) ∧
  (∀ #t2. (CompromiseCA( CA ) @ #t2) ⇒ ¬(#t2 < #t)) ∧
  (∀ #t2. (CompromiseRootCA( rootCA ) @ #t2) ⇒ ¬(#t2 < #t))"
*/
by sorry

lemma A_PKI_Ext_CAfalseAsserts_rootBlamed_suff:
  exists-trace
  "∃ rootCA CA fields ca_fields #t0 #t1 #t2.
    ((((Asserts( 'external auditor',
                 'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                 CA, <fields, ca_fields>
        ) @ #t0) ∧
       (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
        ) @ #t1)) ∧
      (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)) ∧
     (∀ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
       (((Asserts( 'external auditor',
                   'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                   CA.1, <fields.1, ca_fields.1>
          ) @ #t0.1) ∧
         (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                   <ca_fields.1, rootCA.1>
          ) @ #t1.1)) ∧
        (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)) ⇒
       (rootCA.1 = rootCA))) ∧
    ((∀ a #i. (Corrupted( a ) @ #i) ⇒ (a = rootCA)) ∧
     (¬(∃ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
         ((Asserts( 'external auditor',
                    'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                    CA.1, <fields.1, ca_fields.1>
           ) @ #t0.1) ∧
          (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
           ) @ #t1.1)) ∧
         (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1
          ) @ #t2.1))))"
/*
guarded formula characterizing all satisfying traces:
"∃ rootCA CA fields ca_fields #t0 #t1 #t2.
  (Asserts( 'external auditor',
            'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
            CA, <fields, ca_fields>
   ) @ #t0) ∧
  (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
   ) @ #t1) ∧
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)
 ∧
  (∀ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
    (Asserts( 'external auditor',
              'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
              CA.1, <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
              <ca_fields.1, rootCA.1>
     ) @ #t1.1) ∧
    (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)
   ⇒
    rootCA.1 = rootCA) ∧
  (∀ a #i. (Corrupted( a ) @ #i) ⇒ a = rootCA) ∧
  (∀ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
    (Asserts( 'external auditor',
              'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
              CA.1, <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
     ) @ #t1.1) ∧
    (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)
   ⇒
    ⊥)"
*/
by sorry

lemma A_PKI_Ext_CAfalseAsserts_rootNotBlamed_suff:
  exists-trace
  "∃ CA rootCA fields ca_fields #t0 #t1 #t2.
    ((((Asserts( 'external auditor',
                 'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                 CA, <fields, ca_fields>
        ) @ #t0) ∧
       (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
        ) @ #t1)) ∧
      (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)) ∧
     (∀ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
       (((Asserts( 'external auditor',
                   'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                   CA.1, <fields.1, ca_fields.1>
          ) @ #t0.1) ∧
         (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
          ) @ #t1.1)) ∧
        (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)) ⇒
       (CA.1 = CA))) ∧
    ((∀ a #i. (Corrupted( a ) @ #i) ⇒ (a = CA)) ∧
     (¬(∃ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
         ((Asserts( 'external auditor',
                    'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                    CA.1, <fields.1, ca_fields.1>
           ) @ #t0.1) ∧
          (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                    <ca_fields.1, rootCA.1>
           ) @ #t1.1)) ∧
         (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1
          ) @ #t2.1))))"
/*
guarded formula characterizing all satisfying traces:
"∃ CA rootCA fields ca_fields #t0 #t1 #t2.
  (Asserts( 'external auditor',
            'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
            CA, <fields, ca_fields>
   ) @ #t0) ∧
  (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
   ) @ #t1) ∧
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)
 ∧
  (∀ CA.1 rootCA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
    (Asserts( 'external auditor',
              'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
              CA.1, <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
     ) @ #t1.1) ∧
    (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)
   ⇒
    CA.1 = CA) ∧
  (∀ a #i. (Corrupted( a ) @ #i) ⇒ a = CA) ∧
  (∀ rootCA.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
    (Asserts( 'external auditor',
              'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
              CA.1, <fields.1, ca_fields.1>
     ) @ #t0.1) ∧
    (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
              <ca_fields.1, rootCA.1>
     ) @ #t1.1) ∧
    (BrowserAcceptsChain( CA.1, fields.1, rootCA.1, ca_fields.1 ) @ #t2.1)
   ⇒
    ⊥)"
*/
simplify
solve( !Root_CA( $rootCA, pk(x.1) ) ▶₁ #t2 )
  case Root_CA_Init
  solve( Asserts( 'external auditor',
                  'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                  $CA,
                  <<$CA, $id, pkID, 'pubKey', sn, $i, $j>, $rootCA, $CA, pk(x), 
                   'pubKey-CA', snCA, $i0, $j0>
         ) @ #t0 )
    case external_check_false
    solve( !Root_CA( $rootCA, pk(x.1) ) ▶₄ #t0 )
      case Root_CA_Init
      solve( CCADBConsulted( $rootCA,
                             <$rootCA, $CA, pk(x), 'pubKey-CA', snCA, $i0, $j0>
             ) ▶₅ #t0 )
        case ConsultDocumentation_Success
        solve( Asserts( $rootCA, 'I signed this intermediate CA.', $CA,
                        <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn.1, $i0, $j0>
               ) @ #t1 )
          case ConsultDocumentation_Success
          solve( !Root_CA( $rootCA, pk(x) ) ▶₂ #t1 )
            case Root_CA_Init
            solve( !CA_Documentation( $rootCA, $CA,
                                      <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn.1, $i0, $j0>,
                                      sign(<$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn.1, $i0, $j0>, ~skCA.1)
                   ) ▶₃ #t1 )
              case Intermediate_CA_Init
              solve( !KU( sign(<$CA, $id, pkID, 'pubKey', sn, $i, $j>, ~skCA)
                     ) @ #vk.18 )
                case c_sign
                solve( !KU( ~skCA ) @ #vk.30 )
                  case compromiseCA
                  solve( !KU( ~sn.1 ) @ #vk.26 )
                    case Intermediate_CA_Init
                    solve( !KU( sign(<$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn.1, $i0, $j0>,
                                     ~skCA.1)
                           ) @ #vk.30 )
                      case Intermediate_CA_Init
                      solve( !KU( pk(~skCA) ) @ #vk.26 )
                        case Intermediate_CA_Init_case_1
                        SOLVED // trace found
                      qed
                    qed
                  qed
                qed
              qed
            qed
          qed
        qed
      qed
    qed
  qed
qed

lemma A_PKI_Ext_verif_empty:
  all-traces
  "(¬((∃ rootCA CA fields ca_fields #t0 #t1 #t2.
        ((Asserts( 'external auditor',
                   'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                   CA, <fields, ca_fields>
          ) @ #t0) ∧
         (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
          ) @ #t1)) ∧
        (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)) ∨
      (∃ CA rootCA fields ca_fields #t0 #t1 #t2.
        ((Asserts( 'external auditor',
                   'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
                   CA, <fields, ca_fields>
          ) @ #t0) ∧
         (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
          ) @ #t1)) ∧
        (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)))) ⇒
   (∀ CA rootCA ca_fields fields #t0 #t1.
     ((ExternalAuditorCheck( ca_fields, fields ) @ #t0) ∧
      (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t1)) ⇒
     (∃ #t. GroundTruth( CA, fields ) @ #t))"
/*
guarded formula characterizing all counter-examples:
"(∀ rootCA CA fields ca_fields #t0 #t1 #t2.
   (Asserts( 'external auditor',
             'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
             CA, <fields, ca_fields>
    ) @ #t0) ∧
   (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
    ) @ #t1) ∧
   (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)
  ⇒
   ⊥) ∧
 (∀ CA rootCA fields ca_fields #t0 #t1 #t2.
   (Asserts( 'external auditor',
             'That intermediary CA signed the following incorrect statement and the validation chain says the following about that CA.',
             CA, <fields, ca_fields>
    ) @ #t0) ∧
   (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
    ) @ #t1) ∧
   (BrowserAcceptsChain( CA, fields, rootCA, ca_fields ) @ #t2)
