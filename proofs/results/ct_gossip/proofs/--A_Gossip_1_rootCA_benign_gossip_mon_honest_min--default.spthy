lemma A_Gossip_helper [reuse, heuristic=o "acc_oracle"]:
  all-traces
  "∀ M L fields CA ca_fields session gossiped_session #t.
    (((STHGossipCheck( M, L, fields, CA, ca_fields, session, gossiped_session
       ) @ #t) ∧
      (¬(∃ #t.1. CompromiseMonitor( M ) @ #t.1))) ∧
     (¬(∃ #t.1. CompromiseLogger( L ) @ #t.1))) ⇒
    (∃ ca_sig sth chain #t0.
      (MonitorObservesEntry( M, L, fields, <ca_fields, ca_sig>, chain, sth,
                             session
       ) @ #t0) ∧
      (#t0 < #t))"
/*
guarded formula characterizing all counter-examples:
"∃ M L fields CA ca_fields session gossiped_session #t.
  (STHGossipCheck( M, L, fields, CA, ca_fields, session, gossiped_session
   ) @ #t)
 ∧
  (∀ #t.1. (CompromiseMonitor( M ) @ #t.1) ⇒ ⊥) ∧
  (∀ #t.1. (CompromiseLogger( L ) @ #t.1) ⇒ ⊥) ∧
  (∀ ca_sig sth chain #t0.
    (MonitorObservesEntry( M, L, fields, <ca_fields, ca_sig>, chain, sth,
                           session
     ) @ #t0)
   ⇒
    ¬(#t0 < #t))"
*/
by sorry

