rule (modulo E) forge_log_view[color=#d40808]:
   [
   In( <$CA, $id, pkID, 'pre-cert', sn, $i, $j> ), In( preC_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !Corrupted_Logger( $L, skL, pk(skL) )
   ]
  --[
  LoggerComputesAddLogFields( $L, $log_id,
                              <$CA, $id, pkID, 'pubKey', sn, $i, $j>, $now
  ),
  LoggerComputesAddLog( $L, $log_id,
                        <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                        <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        <<<$CA, $id, pkID, 'pre-cert', sn, $i, $j>, preC_sig>, 
                         <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        $now
  ),
  Time( $now ), San_forge_log_view( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) PreCertify[color=#c871ff]:
   [
   !DomainOwner( $id, pkID ), !CA_s0( $CA, skCA, pkCA, ca_fields, ca_sig ),
   Fr( ~sn )
   ]
  --[
  PreCertified( $CA,
                <<$CA, $id, pkID, 'pre-cert', ~sn, $now, $j>, 
                 sign(<$CA, $id, pkID, 'pre-cert', ~sn, $now, $j>, skCA)>
  ),
  GroundTruth( $CA, <$CA, $id, pkID, 'pubKey', ~sn, $now, $j> ),
  Time( $now ), San_PreCertify( )
  ]->
   [
   Out( <$CA, $id, pkID, 'pre-cert', ~sn, $now, $j> ),
   Out( sign(<$CA, $id, pkID, 'pre-cert', ~sn, $now, $j>, skCA) ),
   Certificate_Store( $CA,
                      <<$CA, $id, pkID, 'pre-cert', ~sn, $now, $j>, 
                       sign(<$CA, $id, pkID, 'pre-cert', ~sn, $now, $j>, skCA)>
   ),
   Out( ca_fields ), Out( ca_sig )
   ]

  /* has exactly the trivial AC variant */

restriction Restr_PubKeyCertify_1:
  "∀ x #NOW x.1. (Restr_PubKeyCertify_1( x, x.1 ) @ #NOW) ⇒ (¬(x = x.1))"
  // safety formula

rule (modulo E) PubKeyCertify[color=#c871ff]:
   [
   !CA_s0( $CA, skCA, pkCA, ca_fields, CA_sig ),
   In( <$L1, 'SCT', $sct1, sct1_sig> ), In( <$L2, 'SCT', $sct2, sct2_sig> ),
   !Logger( $L1, pkL1 ), !Logger( $L2, pkL2 ),
   Certificate_Store( $CA,
                      <<$CA, $id, pkID, 'pre-cert', sn, $i, $j>, sig_preC>
   )
   ]
  --[
  Eq( verify(sct1_sig, <$L1, 'SCT', $sct1, $CA, $id, pkID, sn, $i, $j>,
             pkL1),
      true
  ),
  Eq( verify(sct2_sig, <$L2, 'SCT', $sct2, $CA, $id, pkID, sn, $i, $j>,
             pkL2),
      true
  ),
  Eq( verify(sig_preC, <$CA, $id, pkID, 'pre-cert', sn, $i, $j>, pkCA),
      true
  ),
  Certified( $CA, $L1, <$L1, 'SCT', $sct1, sct1_sig>, $L2,
             <$L2, 'SCT', $sct2, sct2_sig>
  ),
  CAAsserts( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j> ),
  CheckValidUntil( $now, $j ), Time( $now ), San_PubKeyCertify( ),
  Restr_PubKeyCertify_1( $L1, $L2 )
  ]->
   [
   Out( <$CA, $id, pkID, 'pubKey', sn, $i, $j, 
         <$L1, 'SCT', $sct1, sct1_sig>, $L2, 'SCT', $sct2, sct2_sig>
   ),
   Out( sign(<$CA, $id, pkID, 'pubKey', sn, $i, $j, 
              <$L1, 'SCT', $sct1, sct1_sig>, $L2, 'SCT', $sct2, sct2_sig>,
             skCA)
   )
   ]

