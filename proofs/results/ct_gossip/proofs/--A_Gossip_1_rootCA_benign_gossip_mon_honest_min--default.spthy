theory ct_gossip begin

// Function signature and definition of the equational theory E

functions: fst/1, pair/2, pk/1, sign/2, snd/1, true/0,
           verify/3[destructor]
equations:
    fst(<x.1, x.2>) = x.1,
    snd(<x.1, x.2>) = x.2,
    verify(sign(fields, sk), fields, pk(sk)) = true





rule (modulo E) Root_CA_Init[color=#620c97]:
   [ Fr( ~skCA ), Fr( ~sn ) ]
  --[
  CA_Registered( $CA, ~skCA, pk(~skCA) ), Root_CA_Init( $CA ),
  Time( $now ), San_Root_CA_Init( )
  ]->
   [
   Out( <$CA, $CA, pk(~skCA), 'selfCert', ~sn, $now, $j> ),
   Out( sign(<$CA, $CA, pk(~skCA), 'selfCert', ~sn, $now, $j>, ~skCA) ),
   Out( <$CA, pk(~skCA)> ), !Root_CA_s0( $CA, ~skCA, pk(~skCA) ),
   !Root_CA( $CA, pk(~skCA) )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Intermediate_CA_Init[color=#c871ff]:
   [ Fr( ~skCA ), Fr( ~sn ), !Root_CA_s0( $rootCA, skRootCA, pkRootCA ) ]
  --[
  CA_Registered( $CA, ~skCA, pk(~skCA) ), NonRoot_CA_Init( $CA ),
  DocumentedCA( $rootCA, $CA,
                <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>
  ),
  Time( $now ), San_Intermediate_CA_Init( )
  ]->
   [
   Out( <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j> ),
   Out( sign(<$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>,
             skRootCA)
   ),
   Out( <$CA, pk(~skCA)> ),
   !CA_s0( $CA, ~skCA, pk(~skCA),
           <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>,
           sign(<$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>, skRootCA)
   ),
   !CA_Documentation( $rootCA, $CA,
                      <$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>,
                      sign(<$rootCA, $CA, pk(~skCA), 'pubKey-CA', ~sn, $now, $j>, skRootCA)
   )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) Domain_Owner_Init[color=#c6c6c6]:
   [ Fr( ~sk ) ]
  --[ Time( $now ), San_Domain_Owner_Init( ) ]->
   [ !DomainOwner( $idServer, pk(~sk) ), Out( pk(~sk) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Monitor_Init:
   [ ]
  --[ Monitor_Registered( $M ), Time( $now ), San_Monitor_Init( ) ]->
   [ !Monitor( $M ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) StartMonitoring[color=#ffdc4e]:
   [ !Monitor( $M ), !Logger( $L, pkL ) ]
  --[ Time( $now ), San_StartMonitoring( ) ]->
   [ !LoggerDict( $M, $L ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) monitorFindsAppendOnlyViolation[color=#e65208]:
   [
   !LoggerDict( $M, $L ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time )
   ]
  --[
  AppendOnlyViolation( $M, $L, sth, session ), Time( $now ),
  San_monitorFindsAppendOnlyViolation( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) monitorVerifiesAppendOnly[color=#e65208]:
   [
   !LoggerDict( $M, $L ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time )
   ]
  --[
  AppendOnlyVerified( $M, $L, sth, session ), Time( $now ),
  San_monitorVerifiesAppendOnly( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) monitorTrackSubject[color=#fac800]:
   [ !Monitor( $M ), !DomainOwner( su, pubK ) ]
  --[ Time( $now ), San_monitorTrackSubject( ) ]->
   [ !TrackSubject( $M, su ) ]

  /* has exactly the trivial AC variant */

restriction rogueCert:
  "∀ CA fields #t1.
    (RogueCert( CA, fields ) @ #t1) ⇒
    (¬(∃ #t0. (GroundTruth( CA, fields ) @ #t0) ∧ (#t0 < #t1)))"
  // safety formula

restriction benignCert:
  "∀ CA fields #t1.
    (BenignCert( CA, fields ) @ #t1) ⇒
    (∃ #t0. (GroundTruth( CA, fields ) @ #t0) ∧ (#t0 < #t1))"

rule (modulo E) ChainValidator_Valid:
   [
   In( <$CA, $subj, ke, 'pre-cert', sn, $i, $j> ), In( cert_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  Eq( verify(cert_sig, <$CA, $subj, ke, 'pre-cert', sn, $i, $j>, pkCA),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  ChainCheck( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
               <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
  ),
  ChainValid( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
               <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
  ),
  San_ChainValidator_Valid( )
  ]->
   [ ]

  /*
  rule (modulo AC) ChainValidator_Valid:
     [
     In( <$CA, $subj, ke, 'pre-cert', sn, $i, $j> ), In( cert_sig ),
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
     !Root_CA( $rootCA, pkRootCA )
     ]
    --[
    Eq( z, true ), Eq( z.1, true ),
    ChainCheck( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
                 <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
    ),
    ChainValid( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
                 <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
    ),
    San_ChainValidator_Valid( )
    ]->
     [ ]
    variants (modulo AC)
    1. $CA   = $CA.33
       $i    = $i.34
       $i0   = $i0.35
       $j    = $j.36
       $j0   = $j0.37
       $rootCA
             = $rootCA.38
       $subj = $subj.39
       ca_sig
             = ca_sig.40
       cert_sig
             = cert_sig.41
       ke    = ke.42
       pkCA  = pkCA.43
       pkRootCA
             = pkRootCA.44
       sn    = sn.45
       snCA  = snCA.46
       z     = verify(cert_sig.41,
                      <$CA.33, $subj.39, ke.42, 'pre-cert', sn.45, $i.34, $j.36>, pkCA.43)
       z.1   = verify(ca_sig.40,
                      <$rootCA.38, $CA.33, pkCA.43, 'pubKey-CA', snCA.46, $i0.35, $j0.37>,
                      pkRootCA.44)
    
    2. $CA   = $CA.47
       $i    = $i.48
       $i0   = $i0.49
       $j    = $j.50
       $j0   = $j0.51
       $rootCA
             = $rootCA.52
       $subj = $subj.53
       ca_sig
             = sign(<$rootCA.52, $CA.47, pkCA.57, 'pubKey-CA', snCA.60, $i0.49, $j0.51
                    >,
                    x.92)
       cert_sig
             = cert_sig.55
       ke    = ke.56
       pkCA  = pkCA.57
       pkRootCA
             = pk(x.92)
       sn    = sn.59
       snCA  = snCA.60
       z     = verify(cert_sig.55,
                      <$CA.47, $subj.53, ke.56, 'pre-cert', sn.59, $i.48, $j.50>, pkCA.57)
       z.1   = true
    
    3. $CA   = $CA.47
       $i    = $i.48
       $i0   = $i0.49
       $j    = $j.50
       $j0   = $j0.51
       $rootCA
             = $rootCA.52
       $subj = $subj.53
       ca_sig
             = sign(<$rootCA.52, $CA.47, pk(x.90), 'pubKey-CA', snCA.60, $i0.49, 
                     $j0.51>,
                    x.92)
       cert_sig
             = sign(<$CA.47, $subj.53, ke.56, 'pre-cert', sn.59, $i.48, $j.50>, x.90)
       ke    = ke.56
       pkCA  = pk(x.90)
       pkRootCA
             = pk(x.92)
       sn    = sn.59
       snCA  = snCA.60
       z     = true
       z.1   = true
    
    4. $CA   = $CA.48
       $i    = $i.49
       $i0   = $i0.50
       $j    = $j.51
       $j0   = $j0.52
       $rootCA
             = $rootCA.53
       $subj = $subj.54
       ca_sig
             = ca_sig.55
       cert_sig
             = sign(<$CA.48, $subj.54, ke.57, 'pre-cert', sn.60, $i.49, $j.51>, x.94)
       ke    = ke.57
       pkCA  = pk(x.94)
       pkRootCA
             = pkRootCA.59
       sn    = sn.60
       snCA  = snCA.61
       z     = true
       z.1   = verify(ca_sig.55,
                      <$rootCA.53, $CA.48, pk(x.94), 'pubKey-CA', snCA.61, $i0.50, $j0.52>,
                      pkRootCA.59)
  */

restriction Restr_ChainValidator_Invalid_1:
  "∀ x #NOW x.1.
    (Restr_ChainValidator_Invalid_1( x, x.1 ) @ #NOW) ⇒
    (¬((x = true) ∧ (x.1 = true)))"
  // safety formula

rule (modulo E) ChainValidator_Invalid:
   [
   In( <$CA, $subj, ke, 'pre-cert', sn, $i, $j> ), In( cert_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  ChainCheck( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
               <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
  ),
  ChainInvalid( <<<$CA, $subj, ke, 'pre-cert', sn, $i, $j>, cert_sig>, 
                 <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
  ),
  San_ChainValidator_Invalid( ),
  Restr_ChainValidator_Invalid_1( verify(cert_sig,
                                         <$CA, $subj, ke, 'pre-cert', sn, $i, $j>, pkCA),
                                  verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
                                         pkRootCA)
  )
  ]->
   [ ]

