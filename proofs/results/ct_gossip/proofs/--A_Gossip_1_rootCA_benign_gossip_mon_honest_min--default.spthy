             = $rootCA.52
       $subj = $subj.53
       ca_sig
             = sign(<$rootCA.52, $CA.47, pk(x.90), 'pubKey-CA', snCA.60, $i0.49, 
                     $j0.51>,
                    x.92)
       cert_sig
             = sign(<$CA.47, $subj.53, ke.56, 'pre-cert', sn.59, $i.48, $j.50>, x.90)
       ke    = ke.56
       pkCA  = pk(x.90)
       pkRootCA
             = pk(x.92)
       sn    = sn.59
       snCA  = snCA.60
       z     = true
       z.1   = true
    
    4. $CA   = $CA.48
       $i    = $i.49
       $i0   = $i0.50
       $j    = $j.51
       $j0   = $j0.52
       $rootCA
             = $rootCA.53
       $subj = $subj.54
       ca_sig
             = ca_sig.55
       cert_sig
             = sign(<$CA.48, $subj.54, ke.57, 'pre-cert', sn.60, $i.49, $j.51>, x.94)
