       ) @ #t.1) ∧
      (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
       ) @ #t1.1) ∧
      (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                <ca_fields.1, rootCA.1>
       ) @ #t2.1) ∧
      (rootCA.1 = rootCA)
     ∧
      (∀ #t.2. (CompromiseMonitor( M.1 ) @ #t.2) ⇒ ⊥) ∧
      (¬(rootCA = rootCA.1))) ∨
    (∃ CA.1 M.1 L.1 fields.1 rootCA.1 ca_fields.1 session.1
       gossiped_session.1 #t.1 #t1.1 #t2.1.
      (STHGossipCheck( M.1, L.1, fields.1, CA.1, ca_fields.1, session.1,
                       gossiped_session.1
       ) @ #t.1) ∧
      (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
       ) @ #t1.1) ∧
      (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
       ) @ #t2.1) ∧
      (CA.1 = rootCA)
     ∧
      (∀ #t.2. (CompromiseMonitor( M.1 ) @ #t.2) ⇒ ⊥) ∧ (¬(rootCA = CA.1)))))"
*/
by sorry

lemma A_Gossip_1_rootCA_benign_gossip_mon_honest_min [heuristic=o "acc_oracle",
                                                      hide_lemma=T_Gossip_verif_empty_helper1,
                                                      hide_lemma=T_Gossip_verif_empty_helper2,
                                                      hide_lemma=A_Gossip_helper]:
  all-traces
  "∀ CA M L fields rootCA ca_fields session gossiped_session #t #t1 #t2.
    ((((STHGossipCheck( M, L, fields, CA, ca_fields, session,
                        gossiped_session
        ) @ #t) ∧
       (Asserts( M, 'Blame this CA.', CA, <fields, ca_fields> ) @ #t1)) ∧
      (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
       ) @ #t2)) ∧
     (¬(∃ #t.1. CompromiseMonitor( M ) @ #t.1))) ⇒
    ((¬(∃ rootCA.1 M.1 L.1 fields.1 CA.1 ca_fields.1 session.1
          gossiped_session.1 #t.1 #t1.1 #t2.1.
         ((((STHGossipCheck( M.1, L.1, fields.1, CA.1, ca_fields.1, session.1,
                             gossiped_session.1
             ) @ #t.1) ∧
            (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
             ) @ #t1.1)) ∧
           (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                     <ca_fields.1, rootCA.1>
            ) @ #t2.1)) ∧
          (¬(∃ #t.2. CompromiseMonitor( M.1 ) @ #t.2))) ∧
         ((rootCA.1 = CA) ∧ (¬(CA = rootCA.1))))) ∧
     (¬(∃ CA.1 M.1 L.1 fields.1 rootCA.1 ca_fields.1 session.1
          gossiped_session.1 #t.1 #t1.1 #t2.1.
         ((((STHGossipCheck( M.1, L.1, fields.1, CA.1, ca_fields.1, session.1,
                             gossiped_session.1
             ) @ #t.1) ∧
            (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
             ) @ #t1.1)) ∧
           (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
            ) @ #t2.1)) ∧
          (¬(∃ #t.2. CompromiseMonitor( M.1 ) @ #t.2))) ∧
         ((CA.1 = CA) ∧ (¬(CA = CA.1))))))"
/*
guarded formula characterizing all counter-examples:
"∃ CA M L fields rootCA ca_fields session gossiped_session #t #t1 #t2.
  (STHGossipCheck( M, L, fields, CA, ca_fields, session, gossiped_session
   ) @ #t) ∧
  (Asserts( M, 'Blame this CA.', CA, <fields, ca_fields> ) @ #t1) ∧
  (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
   ) @ #t2)
 ∧
  (∀ #t.1. (CompromiseMonitor( M ) @ #t.1) ⇒ ⊥) ∧
  (((∃ rootCA.1 M.1 L.1 fields.1 CA.1 ca_fields.1 session.1
       gossiped_session.1 #t.1 #t1.1 #t2.1.
      (STHGossipCheck( M.1, L.1, fields.1, CA.1, ca_fields.1, session.1,
                       gossiped_session.1
       ) @ #t.1) ∧
      (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
       ) @ #t1.1) ∧
      (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                <ca_fields.1, rootCA.1>
       ) @ #t2.1) ∧
      (rootCA.1 = CA)
     ∧
      (∀ #t.2. (CompromiseMonitor( M.1 ) @ #t.2) ⇒ ⊥) ∧ (¬(CA = rootCA.1))) ∨
    (∃ CA.1 M.1 L.1 fields.1 rootCA.1 ca_fields.1 session.1
       gossiped_session.1 #t.1 #t1.1 #t2.1.
      (STHGossipCheck( M.1, L.1, fields.1, CA.1, ca_fields.1, session.1,
                       gossiped_session.1
       ) @ #t.1) ∧
      (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
       ) @ #t1.1) ∧
      (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
       ) @ #t2.1) ∧
      (CA.1 = CA)
     ∧
      (∀ #t.2. (CompromiseMonitor( M.1 ) @ #t.2) ⇒ ⊥) ∧ (¬(CA = CA.1)))))"
*/
simplify
solve( Asserts( $M, 'Blame this CA.', $CA,
                <<$CA, $subj, ke, 'pubKey', sn, $i, $j>, $rootCA, $CA, pk(x), 
                 'pubKey-CA', snCA, $i0, $j0>
       ) @ #t1 )
  case monitorFindsRogueCertificate
  solve( Asserts( rootCA.1, 'I signed this intermediate CA.', $CA,
                  <$rootCA, $CA, pk(x), 'pubKey-CA', snCA, $i0, $j0>
         ) @ #t2.1 )
    case ConsultDocumentation_Success
    solve( (∃ rootCA M L fields CA.1 ca_fields session gossiped_session #t
              #t1 #t2.
             (STHGossipCheck( M, L, fields, CA.1, ca_fields, session, gossiped_session
              ) @ #t) ∧
             (Asserts( M, 'Blame this CA.', CA.1, <fields, ca_fields> ) @ #t1) ∧
             (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
                       <ca_fields, rootCA>
              ) @ #t2) ∧
             (rootCA = $CA)
            ∧
             (∀ #t.1. (CompromiseMonitor( M ) @ #t.1) ⇒ ⊥) ∧ (¬($CA = rootCA)))  ∥
           (∃ CA.1 M L fields rootCA ca_fields session gossiped_session #t #t1 #t2.
             (STHGossipCheck( M, L, fields, CA.1, ca_fields, session, gossiped_session
              ) @ #t) ∧
             (Asserts( M, 'Blame this CA.', CA.1, <fields, ca_fields> ) @ #t1) ∧
             (Asserts( rootCA, 'I signed this intermediate CA.', CA.1, ca_fields
              ) @ #t2) ∧
             (CA.1 = $CA)
            ∧
             (∀ #t.1. (CompromiseMonitor( M ) @ #t.1) ⇒ ⊥) ∧ (¬($CA = CA.1))) )
      case case_1
      by contradiction /* from formulas */
    next
      case case_2
      by contradiction /* from formulas */
    qed
  qed
qed

