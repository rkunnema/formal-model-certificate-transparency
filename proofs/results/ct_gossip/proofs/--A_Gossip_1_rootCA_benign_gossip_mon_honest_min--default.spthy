rule (modulo E) monitorCanFindCertificate[color=#f3d664]:
   [
   !LoggerDict( $M, $L ), !TrackSubject( $M, $subj ),
   In( <$CA, $subj, ke, 'pubKey', sn, $i, $j, sct1, sct2> ), In( cert_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   In( preC_fields ), In( preC_sig ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  Eq( verify(cert_sig, <$CA, $subj, ke, 'pubKey', sn, $i, $j, sct1, sct2>,
             pkCA),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  MonitorObservesEntry( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                        <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        <<preC_fields, preC_sig>, 
                         <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        sth, session
  ),
  BenignCert( $iss, <$CA, $subj, ke, 'pubKey', sn, $i, $j> ),
  Asserts( $M, 'Do not blame this CA.', $CA,
           <<$CA, $subj, ke, 'pubKey', sn, $i, $j>, $rootCA, $CA, pkCA, 
            'pubKey-CA', snCA, $i0, $j0>
  ),
  MonitorScanLog( ), Time( $now ), San_monitorCanFindCertificate( )
  ]->
   [
   MonitorFoundCert( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
   ),
   MonitorInspected( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
   )
   ]

