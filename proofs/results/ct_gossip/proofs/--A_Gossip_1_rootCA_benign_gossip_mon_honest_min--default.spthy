rule (modulo E) MonitorStoresSnapshot:
   [
   !Logger( $L, pkL ), !Monitor( $M ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time )
   ]
  --[
  SnapshotStored( $M, $L, session, sth ), Time( $now ),
  San_MonitorStoresSnapshot( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) ClientStoresSnapshot:
   [ !Logger( $L, pkL ), !TLS_L_to_C( $L, $C, $snapshot, sth, session ) ]
  --[
  SnapshotStored( $C, $L, session, sth ), Time( $now ),
  San_ClientStoresSnapshot( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) ClientFindsAppendOnlyViolation[color=#e65208]:
   [ !Logger( $L, pkL ), !TLS_L_to_C( $L, $C, $snapshot, sth, session ) ]
  --[
  ClientFindsAppendOnlyViolation( $L ),
  AppendOnlyViolation( $C, $L, sth, session ), Time( $now ),
  San_ClientFindsAppendOnlyViolation( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

restriction AppendOnlyFails:
  "∀ sth session id L #t6.
    (AppendOnlyViolation( id, L, sth, session ) @ #t6) ⇒
    (∃ fields ca_cert chain time t log_id1 log_id2 time2 sth2 session2 #t0
       #t1 #t2 #t3 #t4 #t5.
      ((((((((((((((LoggerComputesAddLog( L, log_id1, fields, ca_cert, chain, t
                    ) @ #t0) ∧
                   (∃ different_time #t.1.
                     ((LoggerComputesAddLog( L, log_id1, fields, ca_cert, chain,
                                             different_time
                       ) @ #t.1) ∧
                      (¬(time = different_time))) ∧
                     (#t.1 < #t2))) ∧
                  (FetchLogSnapshot( id, L, session2 ) @ #t1)) ∧
                 (LoggerPresentsView( L, id, log_id1, time, sth2, session2 ) @ #t2)) ∧
                (SnapshotStored( id, L, session2, sth2 ) @ #t3)) ∧
               (FetchLogSnapshot( id, L, session ) @ #t4)) ∧
              (LoggerPresentsView( L, id, log_id2, time2, sth, session ) @ #t5)) ∧
             (¬(∃ ca_cert.1 different_time chain.1 #t.1.
                 ((LoggerComputesAddLog( L, log_id2, fields, ca_cert.1, chain.1,
                                         different_time
                   ) @ #t.1) ∧
                  (¬(time2 = different_time))) ∧
                 (#t.1 < #t5)))) ∧
            (#t0 < #t1)) ∧
           (#t1 < #t2)) ∧
          (#t2 < #t3)) ∧
         (#t2 < #t4)) ∧
        (#t4 < #t5)) ∧
       (#t3 < #t5)) ∧
      (#t5 < #t6))"

rule (modulo E) ClientVerifiesAppendOnly[color=#c1ff3c]:
   [
   !TLS_L_to_C( $L, $C, $snapshot, sth, session ), !Logger( $L, pkL ),
   In( $idUser )
   ]
  --[
  AppendOnlyVerified( $idUser, $L, sth, session ), Time( $now ),
  San_ClientVerifiesAppendOnly( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

restriction appendOnlyWorks:
  "(∀ id L sth session time1 t log_id log_id2 fields ca_cert chain sth2
      session2 time2 #t0 #t1 #t2 #t4 #t5.
     ((((((((((AppendOnlyVerified( id, L, sth, session ) @ #t5) ∧
              (LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, t ) @ #t0)) ∧
             (∃ different_time #t.1.
               ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
                 ) @ #t.1) ∧
                (¬(time1 = different_time))) ∧
               (#t.1 < #t1))) ∧
            (LoggerPresentsView( L, id, log_id, time1, sth2, session2 ) @ #t1)) ∧
           (SnapshotStored( id, L, session2, sth2 ) @ #t2)) ∧
          (LoggerPresentsView( L, id, log_id2, time2, sth, session ) @ #t4)) ∧
         (#t0 < #t1)) ∧
        (#t1 < #t2)) ∧
       (#t2 < #t4)) ∧
      (#t4 < #t5)) ⇒
     (∃ different_time #t.1.
       ((LoggerComputesAddLog( L, log_id2, fields, ca_cert, chain,
                               different_time
         ) @ #t.1) ∧
        (¬(time2 = different_time))) ∧
       (#t.1 < #t4))) ∧
   (∀ id L sth session #t5.
     (AppendOnlyVerified( id, L, sth, session ) @ #t5) ⇒
     (∃ time1 t log_id log_id2 fields ca_cert chain sth2 session2 time2 #t0
        #t1 #t2 #t4.
       ((((((((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, t
               ) @ #t0) ∧
              (∃ different_time #t.1.
                ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
                  ) @ #t.1) ∧
                 (¬(time1 = different_time))) ∧
                (#t.1 < #t1))) ∧
             (LoggerPresentsView( L, id, log_id, time1, sth2, session2 ) @ #t1)) ∧
            (SnapshotStored( id, L, session2, sth2 ) @ #t2)) ∧
           (LoggerPresentsView( L, id, log_id2, time2, sth, session ) @ #t4)) ∧
          (#t0 < #t1)) ∧
         (#t1 < #t2)) ∧
        (#t2 < #t4)) ∧
       (#t4 < #t5)))"

rule (modulo E) ProofFetching_M[color=#10bcc5]:
   [ Fr( ~session ), !Monitor( $M ), !Logger( $L, pkL ) ]
  --[
  FetchLogSnapshot( $M, $L, ~session ), Time( $now ),
  San_ProofFetching_M( )
  ]->
   [ TLS_M_to_L( $M, $L, ~session, $now ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ProofFetching_C[color=#10bcc5]:
   [ Fr( ~session ), In( $C ), !Logger( $L, pkL ) ]
  --[
  FetchLogSnapshot( $C, $L, ~session ), Time( $now ),
  San_ProofFetching_C( )
  ]->
   [ TLS_C_to_L( $C, $L, ~session ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) ProofFetching_P[color=#10bcc5]:
   [ Fr( ~session ), In( $P ), !Logger( $L, pkL ) ]
  --[
  FetchLogSnapshot( $P, $L, ~session ), Time( $now ),
  San_ProofFetching_P( )
  ]->
   [ TLS_P_to_L( $P, $L, ~session, $now ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) LoggerSnapshot_M[color=#22d6d6]:
   [
   !Logger_s( $L, skL, pk(skL) ), Fr( ~sth ),
   TLS_M_to_L( $M, $L, session, $time )
   ]
  --[
  LoggerPresentsView( $L, $M, $log_id, $now, ~sth, session ),
  LoggerHandsOutSTH( $L, ~sth, session ), Time( $now ),
  San_LoggerSnapshot_M( )
  ]->
   [ !TLS_L_to_M( $L, $M, $snapshot, ~sth, session, $time ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) LoggerSnapshot_C[color=#22d6d6]:
   [
   !Logger_s( $L, skL, pk(skL) ), Fr( ~sth ), TLS_C_to_L( $C, $L, session )
   ]
  --[
  LoggerPresentsView( $L, $C, $log_id, $now, ~sth, session ),
  LoggerHandsOutSTH( $L, ~sth, session ), Time( $now ),
  San_LoggerSnapshot_C( )
  ]->
   [ !TLS_L_to_C( $L, $C, $snapshot, ~sth, session ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) LoggerSnapshot_P[color=#22d6d6]:
   [
   !Logger_s( $L, skL, pk(skL) ), Fr( ~sth ),
   TLS_P_to_L( $P, $L, session, $time )
   ]
  --[
  LoggerPresentsView( $L, $P, $log_id, $now, ~sth, session ),
  LoggerHandsOutSTH( $L, ~sth, session ), Time( $now ),
  San_LoggerSnapshot_P( )
  ]->
   [ !TLS_L_to_P( $L, $P, $snapshot, ~sth, session, $time ) ]

  /* has exactly the trivial AC variant */

restriction only_existing_log_ids:
  "∀ L idR log_id time sth session #t1.
    (LoggerPresentsView( L, idR, log_id, time, sth, session ) @ #t1) ⇒
    (∃ #t0. (StartedLog( L, log_id ) @ #t0) ∧ (#t0 < #t1))"

rule (modulo E) ParticipantFindsInclusionViolation[color=#e65208]:
   [
   !TLS_L_to_P( $L, $P, $snapshot, sth, session, $time ),
   !Logger( $L, pkL ), In( <$CA, $id, pkID, 'pubKey', sn, $i, $j> ),
   In( ca_cert )
   ]
  --[
  Asserts( $P, 'This loggers log currently does not include these fields.',
           $L, <<$CA, $id, pkID, 'pubKey', sn, $i, $j>, session>
  ),
  InclusionProofFails( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                       ca_cert, sth, session
  ),
  Time( $now ), San_ParticipantFindsInclusionViolation( )
  ]->
   [
   InclusionFailed( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>, ca_cert,
                    $time, session
   )
   ]

  /* has exactly the trivial AC variant */

restriction inclusionProofFails:
  "∀ IdFetcher L fields ca_cert sth session #t1.
    (InclusionProofFails( IdFetcher, L, fields, ca_cert, sth, session
     ) @ #t1) ⇒
    (∃ log_id time #t0.
      ((LoggerPresentsView( L, IdFetcher, log_id, time, sth, session ) @ #t0) ∧
       (#t0 < #t1)) ∧
      (¬(∃ ca_cert.1 different_time chain #t.
          ((LoggerComputesAddLog( L, log_id, fields, ca_cert.1, chain,
                                  different_time
            ) @ #t) ∧
           (¬(time = different_time))) ∧
          (#t < #t0))))"

rule (modulo E) ParticipantVerifiesInclusion[color=#c1ff3c]:
   [
   !TLS_L_to_P( $L, $P, $snapshot, sth, session, $time ),
   !Logger( $L, pkL ), In( <$CA, $id, pkID, 'pubKey', sn, $i, $j> ),
   In( ca_cert ), In( chain )
   ]
  --[
  InclusionProofSucceeds( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                          ca_cert, chain, sth, session
  ),
  Asserts( $P, 'This loggers log currently includes these fields.', $L,
           <<$CA, $id, pkID, 'pubKey', sn, $i, $j>, session>
  ),
  Time( $now ), San_ParticipantVerifiesInclusion( )
  ]->
   [
   InclusionVerified( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>, $time,
                      session, chain
   )
   ]

  /* has exactly the trivial AC variant */

restriction inclusionProofWorks:
  "∀ IdFetcher L fields ca_cert chain sth session #t5.
    (InclusionProofSucceeds( IdFetcher, L, fields, ca_cert, chain, sth,
                             session
     ) @ #t5) ⇒
    (∃ id log_id time #t2.
      ((LoggerPresentsView( L, id, log_id, time, sth, session ) @ #t2) ∧
       (#t2 < #t5)) ∧
      (∃ different_time #t.
        ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
          ) @ #t) ∧
         (¬(time = different_time))) ∧
        (#t < #t2)))"

rule (modulo E) MonitorFindsInclusionViolation[color=#e65208]:
