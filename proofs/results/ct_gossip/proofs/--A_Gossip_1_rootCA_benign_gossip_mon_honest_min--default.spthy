rule (modulo E) monitorCannotFindCertificate[color=#f3d664]:
   [
   !LoggerDict( $M, $L ), !TrackSubject( $M, su ),
   In( <$CA, $subj, ke, 'pubKey', sn, $i, $j> ), In( cert_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  NothingObserved( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, sth,
                   session
  ),
  Asserts( $M, 'Do not blame this CA.', $CA,
           <<$CA, $subj, ke, 'pubKey', sn, $i, $j>, $rootCA, $CA, pkCA, 
            'pubKey-CA', snCA, $i0, $j0>
  ),
  MonitorScanLog( ), Time( $now ), San_monitorCannotFindCertificate( )
  ]->
   [
   MonitorCouldNotFindCert( $M, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $L,
                            $CA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
   ),
   MonitorInspected( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
   )
   ]

  /* has exactly the trivial AC variant */

