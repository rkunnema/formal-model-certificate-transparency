restriction Restr_ClientValidate_1:
  "∀ x #NOW x.1. (Restr_ClientValidate_1( x, x.1 ) @ #NOW) ⇒ (¬(x = x.1))"
  // safety formula

rule (modulo E) ClientValidate[color=#f2ce03]:
   [
   !Root_CA( $rootCA, pkRootCA ),
   In( <
        <
         <$CA, $id, pkID, 'pubKey', sn, $i, $j, <$L1, 'SCT', $sct1, sct1_sig>, 
          $L2, 'SCT', $sct2, sct2_sig>, 
         pub_sig>, 
        <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
   ),
   !Logger( $L1, pkL1 ), !Logger( $L2, pkL2 )
   ]
  --[
  BrowserAcceptsChain( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                       $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $L2
  ),
  Eq( verify(pub_sig,
             <$CA, $id, pkID, 'pubKey', sn, $i, $j, <$L1, 'SCT', $sct1, sct1_sig>, 
              $L2, 'SCT', $sct2, sct2_sig>,
             pkCA),
      true
  ),
  Eq( verify(sct1_sig, <$L1, 'SCT', $sct1, $CA, $id, pkID, sn, $i, $j>,
             pkL1),
      true
  ),
  Eq( verify(sct2_sig, <$L2, 'SCT', $sct2, $CA, $id, pkID, sn, $i, $j>,
             pkL2),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  CheckValidUntil( $now, $j ), CheckValidUntil( $now, $j0 ), Time( $now ),
  San_ClientValidate( ), Restr_ClientValidate_1( $L1, $L2 )
  ]->
   [
   !BAccept_SCT( $L1, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                 <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>
   ),
   !BAccept_SCT( $L2, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                 <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>
   )
   ]

  /*
  rule (modulo AC) ClientValidate[color=#f2ce03]:
     [
     !Root_CA( $rootCA, pkRootCA ),
     In( <
