   (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
    ) @ #t2)
  ⇒
   ((∃ #t.1. (CompromiseLogger( L ) @ #t.1)) ∨
    (∃ #t.1. (CompromiseMonitor( M ) @ #t.1)))) ∧
 (∃ M L L1 L2 fields CA ca_fields session gossiped_session rootCA #t0 #t1.
   (STHGossipCheck( M, L, fields, CA, ca_fields, session, gossiped_session
    ) @ #t0) ∧
   (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #t1)
  ∧
   (((L1 = L) ∨ (L2 = L))) ∧
   (∀ #t. (CompromiseLogger( L ) @ #t) ⇒ ⊥) ∧
   (∀ #t. (CompromiseMonitor( M ) @ #t) ⇒ ⊥) ∧
