    ]->
     [ ]
    variants (modulo AC)
    1. $CA   = $CA.33
       $i    = $i.34
       $i0   = $i0.35
       $j    = $j.36
       $j0   = $j0.37
       $rootCA
             = $rootCA.38
       $subj = $subj.39
       ca_sig
             = ca_sig.40
