lemma A_Gossip_2_verif_empty [heuristic=o "acc_oracle",
                              hide_lemma=T_Gossip_verif_empty_helper1,
                              hide_lemma=T_Gossip_verif_empty_helper2]:
  all-traces
  "(¬((∃ rootCA M L fields CA ca_fields session gossiped_session #t #t1
         #t2.
        ((((STHGossipCheck( M, L, fields, CA, ca_fields, session,
                            gossiped_session
            ) @ #t) ∧
           (Asserts( M, 'Blame this CA.', CA, <fields, ca_fields> ) @ #t1)) ∧
          (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
           ) @ #t2)) ∧
         (¬(∃ #t.1. CompromiseLogger( L ) @ #t.1))) ∧
        (¬(∃ #t.1. CompromiseMonitor( M ) @ #t.1))) ∨
      (∃ CA M L fields rootCA ca_fields session gossiped_session #t #t1 #t2.
        ((((STHGossipCheck( M, L, fields, CA, ca_fields, session,
                            gossiped_session
            ) @ #t) ∧
           (Asserts( M, 'Blame this CA.', CA, <fields, ca_fields> ) @ #t1)) ∧
          (Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields
           ) @ #t2)) ∧
         (¬(∃ #t.1. CompromiseLogger( L ) @ #t.1))) ∧
        (¬(∃ #t.1. CompromiseMonitor( M ) @ #t.1))))) ⇒
   (∀ M L L1 L2 fields CA ca_fields session gossiped_session rootCA #t0 #t1.
     (((((STHGossipCheck( M, L, fields, CA, ca_fields, session,
                          gossiped_session
          ) @ #t0) ∧
         (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #t1)) ∧
        ((L1 = L) ∨ (L2 = L))) ∧
       (¬(∃ #t. CompromiseLogger( L ) @ #t))) ∧
      (¬(∃ #t. CompromiseMonitor( M ) @ #t))) ⇒
     (∃ #t. GroundTruth( CA, fields ) @ #t))"
/*
guarded formula characterizing all counter-examples:
"(∀ rootCA M L fields CA ca_fields session gossiped_session #t #t1 #t2.
   (STHGossipCheck( M, L, fields, CA, ca_fields, session, gossiped_session
    ) @ #t) ∧
   (Asserts( M, 'Blame this CA.', CA, <fields, ca_fields> ) @ #t1) ∧
   (Asserts( 'CCADB', 'No root CA signed this CA.', CA, <ca_fields, rootCA>
    ) @ #t2)
  ⇒
   ((∃ #t.1. (CompromiseLogger( L ) @ #t.1)) ∨
