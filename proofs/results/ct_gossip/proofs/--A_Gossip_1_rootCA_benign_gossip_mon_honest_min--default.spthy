lemma authenticity:
  exists-trace
  "∃ L1 L2 rootCA ca_fields CA fields #j.
    (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #j) ∧
    (¬(∃ #i. (GroundTruth( CA, fields ) @ #i) ∧ (#i < #j)))"
/*
guarded formula characterizing all satisfying traces:
"∃ L1 L2 rootCA ca_fields CA fields #j.
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #j)
 ∧
  ∀ #i. (GroundTruth( CA, fields ) @ #i) ⇒ ¬(#i < #j)"
*/
by sorry

lemma transparency_Gossip [heuristic=o "acc_oracle"]:
  all-traces
  "∀ M L L1 L2 CA rootCA fields ca_fields session gossiped_session #t0 #t1.
    ((((BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #t0) ∧
       (STHGossipTransparencyCheck( M, L, fields, CA, ca_fields, session,
                                    gossiped_session
        ) @ #t1)) ∧
      ((L1 = L) ∨ (L2 = L))) ∧
     (#t0 < #t1)) ⇒
    (CTGossipTransparencyCheckSuccess( M, L, fields, CA, ca_fields, session,
                                       gossiped_session
     ) @ #t1)"
/*
guarded formula characterizing all counter-examples:
"∃ M L L1 L2 CA rootCA fields ca_fields session gossiped_session #t0 #t1.
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, L1, L2 ) @ #t0) ∧
  (STHGossipTransparencyCheck( M, L, fields, CA, ca_fields, session,
                               gossiped_session
   ) @ #t1)
 ∧
  (((L1 = L) ∨ (L2 = L))) ∧
  (#t0 < #t1) ∧
  (¬(CTGossipTransparencyCheckSuccess( M, L, fields, CA, ca_fields,
                                       session, gossiped_session
     ) @ #t1))"
*/
by sorry

lemma T_Gossip_verif_empty_helper1 [reuse, heuristic=o "acc_oracle"]:
  all-traces
  "∀ M L fields CA ca_fields gossiped_session session #t.
    ((STHGossipTransparencyCheck( M, L, fields, CA, ca_fields, session,
                                  gossiped_session
      ) @ #t) ∧
     (¬(∃ #t.1.
         Asserts( M,
                  'The log has violated the append-only property between these two snapshots.',
                  L, <gossiped_session, session>
         ) @ #t.1))) ⇒
    (CTGossipTransparencyCheckSuccess( M, L, fields, CA, ca_fields, session,
                                       gossiped_session
     ) @ #t)"
/*
guarded formula characterizing all counter-examples:
"∃ M L fields CA ca_fields gossiped_session session #t.
  (STHGossipTransparencyCheck( M, L, fields, CA, ca_fields, session,
                               gossiped_session
   ) @ #t)
 ∧
  (∀ #t.1.
    (Asserts( M,
              'The log has violated the append-only property between these two snapshots.',
              L, <gossiped_session, session>
     ) @ #t.1)
   ⇒
    ⊥) ∧
  (¬(CTGossipTransparencyCheckSuccess( M, L, fields, CA, ca_fields,
                                       session, gossiped_session
     ) @ #t))"
*/
by sorry

lemma T_Gossip_verif_empty_helper2 [reuse,
                                    hide_lemma=T_Gossip_verif_empty_helper1, heuristic=o "acc_oracle"]:
