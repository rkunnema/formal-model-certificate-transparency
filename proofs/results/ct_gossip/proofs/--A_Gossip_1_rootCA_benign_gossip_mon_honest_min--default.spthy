rule (modulo E) clientGossipsToMonitor:
   [
   !TLS_L_to_P( $L, $C, $snapshot, sth, session, $time ),
   InclusionVerified( $C, $L, fields, $time, session, chain ),
   !BAccept_SCT( $L, fields, ca_fields )
   ]
  --[
  Time( $now ), San_clientGossipsToMonitor( ),
  ClientGossips( $C, $L, fields, $time, session, chain )
  ]->
   [
   !TLS_C_to_M( $C, $M, $snapshot, sth, session ),
   ClientGossiped( $C, $M, $L, session, $time, fields, ca_fields, chain )
   ]

  /* has exactly the trivial AC variant */

rule (modulo E) monitorFindsAppendOnlyViolation_Gossiped[color=#501755]:
   [
   !LoggerDict( $M, $L ),
   !TLS_C_to_M( $C, $M, $gos_snapshot, gossiped_sth, gossiped_session ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time )
   ]
  --[
  Gos_AppendOnlyViol( $M, $L, sth, session, gossiped_sth, gossiped_session
  ),
  Asserts( $M,
           'The log has violated the append-only property between these two snapshots.',
           $L, <gossiped_session, session>
  ),
  MonitorReceivesGossip( $M, $L, gossiped_session, session ), Time( $now ),
  San_monitorFindsAppendOnlyViolation_Gossiped( )
  ]->
   [ AppendOnlyChecked( $M, gossiped_session, session ) ]

  /* has exactly the trivial AC variant */

restriction appendOnlyFails_Gossiped:
  "∀ M L session sth gossiped_sth gossiped_session #t5.
    (Gos_AppendOnlyViol( M, L, sth, session, gossiped_sth, gossiped_session
     ) @ #t5) ⇒
    (∃ id1 fields ca_cert chain time t time2 log_id log_id2 #t0 #t1 #t2 #t3
       #t4.
      (((((((((((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, t
                 ) @ #t0) ∧
                (∃ different_time #t.1.
                  ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
                    ) @ #t.1) ∧
                   (¬(time = different_time))) ∧
                  (#t.1 < #t2))) ∧
               (FetchLogSnapshot( id1, L, gossiped_session ) @ #t1)) ∧
              (LoggerPresentsView( L, id1, log_id, time, gossiped_sth, gossiped_session
               ) @ #t2)) ∧
             (FetchLogSnapshot( M, L, session ) @ #t3)) ∧
            (LoggerPresentsView( L, M, log_id2, time2, sth, session ) @ #t4)) ∧
           (¬(∃ ca_cert.1 different_time chain.1 #t.1.
               ((LoggerComputesAddLog( L, log_id2, fields, ca_cert.1, chain.1,
                                       different_time
                 ) @ #t.1) ∧
                (¬(time2 = different_time))) ∧
               (#t.1 < #t4)))) ∧
          (#t0 < #t1)) ∧
         (#t1 < #t2)) ∧
        (#t2 < #t3)) ∧
       (#t3 < #t4)) ∧
      (#t4 < #t5))"

rule (modulo E) monitorVerifiesAppendOnly_Gossiped[color=#501755]:
   [
   !LoggerDict( $M, $L ),
   !TLS_C_to_M( $C, $M, $gos_snapshot, gossiped_sth, gossiped_session ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time )
   ]
  --[
  AppendOnlyVerified_Gossiped( $M, $L, sth, session, gossiped_sth,
                               gossiped_session
  ),
  Asserts( $M,
           'The log has not violated the append-only property between these two snapshots.',
           $L, <gossiped_session, session>
  ),
  MonitorReceivesGossip( $M, $L, gossiped_session, session ),
  MonitorReceivesGossip_Verified( $M, $L, gossiped_session, session ),
  Time( $now ), San_monitorVerifiesAppendOnly_Gossiped( )
  ]->
   [ AppendOnlyChecked( $M, gossiped_session, session ) ]

  /* has exactly the trivial AC variant */

restriction appendOnlyWorks_Gossiped:
  "(∀ id1 M L sth session time1 t log_id log_id2 fields ca_cert chain
      gossiped_sth gossiped_session time2 #t0 #t1 #t4 #t5.
     ((((((((AppendOnlyVerified_Gossiped( M, L, sth, session, gossiped_sth,
                                          gossiped_session
             ) @ #t5) ∧
            (LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, t ) @ #t0)) ∧
           (∃ different_time #t.1.
             ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
               ) @ #t.1) ∧
              (¬(time1 = different_time))) ∧
             (#t.1 < #t1))) ∧
          (LoggerPresentsView( L, id1, log_id, time1, gossiped_sth,
                               gossiped_session
           ) @ #t1)) ∧
         (LoggerPresentsView( L, M, log_id2, time2, sth, session ) @ #t4)) ∧
        (#t0 < #t1)) ∧
       (#t1 < #t4)) ∧
      (#t4 < #t5)) ⇒
     (∃ different_time #t.1.
       ((LoggerComputesAddLog( L, log_id2, fields, ca_cert, chain,
                               different_time
         ) @ #t.1) ∧
        (¬(time2 = different_time))) ∧
       (#t.1 < #t4))) ∧
   (∀ M L sth session gossiped_sth gossiped_session #t5.
     (AppendOnlyVerified_Gossiped( M, L, sth, session, gossiped_sth,
                                   gossiped_session
      ) @ #t5) ⇒
     (∃ id1 time1 log_id log_id2 fields ca_cert chain time2 t #t0 #t1 #t4.
       (((((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, t
            ) @ #t0) ∧
           (∃ different_time #t.1.
             ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
               ) @ #t.1) ∧
              (¬(time1 = different_time))) ∧
             (#t.1 < #t1))) ∧
          (LoggerPresentsView( L, id1, log_id, time1, gossiped_sth,
                               gossiped_session
           ) @ #t1)) ∧
         (LoggerPresentsView( L, M, log_id2, time2, sth, session ) @ #t4)) ∧
        (#t1 < #t4)) ∧
       (#t4 < #t5)))"

rule (modulo E) ConsultDocumentation_Success:
   [
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRCA ),
   !CA_Documentation( $rootCA, $CA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, ca_sig
   )
   ]
  --[
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, pkRCA),
      true
  ),
  Asserts( $rootCA, 'I signed this intermediate CA.', $CA,
           <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  ExternalCheckCCADB( $rootCA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Time( $now ), San_ConsultDocumentation_Success( )
  ]->
   [
   CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
   ]

  /*
  rule (modulo AC) ConsultDocumentation_Success:
     [
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
     !Root_CA( $rootCA, pkRCA ),
     !CA_Documentation( $rootCA, $CA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, ca_sig
     )
     ]
    --[
    Eq( z, true ),
    Asserts( $rootCA, 'I signed this intermediate CA.', $CA,
             <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    ExternalCheckCCADB( $rootCA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Time( $now ), San_ConsultDocumentation_Success( )
    ]->
     [
     CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
     ]
    variants (modulo AC)
    1. $CA   = $CA.21
       $i    = $i.22
       $j    = $j.23
       $rootCA
             = $rootCA.25
       ca_sig
             = ca_sig.26
       pkCA  = pkCA.27
       pkRCA = pkRCA.28
       sn    = sn.29
       z     = verify(ca_sig.26,
                      <$rootCA.25, $CA.21, pkCA.27, 'pubKey-CA', sn.29, $i.22, $j.23>,
                      pkRCA.28)
    
    2. $CA   = $CA.32
       $i    = $i.33
       $j    = $j.34
       $rootCA
             = $rootCA.36
       ca_sig
             = sign(<$rootCA.36, $CA.32, pkCA.38, 'pubKey-CA', sn.40, $i.33, $j.34>,
                    x.62)
       pkCA  = pkCA.38
       pkRCA = pk(x.62)
       sn    = sn.40
       z     = true
  */

rule (modulo E) ConsultDocumentation_Fails:
   [
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRCA )
   ]
  --[
  UndocumentedIntermediateCA( $rootCA, $CA,
                              <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Asserts( 'CCADB', 'No root CA signed this CA.', $CA,
           <<$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, $rootCA>
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, pkRCA),
      true
  ),
  ExternalCheckCCADB( $rootCA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Time( $now ), San_ConsultDocumentation_Fails( )
  ]->
   [
   CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
   ]

  /*
  rule (modulo AC) ConsultDocumentation_Fails:
     [
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
     !Root_CA( $rootCA, pkRCA )
     ]
    --[
    UndocumentedIntermediateCA( $rootCA, $CA,
                                <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Asserts( 'CCADB', 'No root CA signed this CA.', $CA,
             <<$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, $rootCA>
    ),
    Eq( z, true ),
    ExternalCheckCCADB( $rootCA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Time( $now ), San_ConsultDocumentation_Fails( )
    ]->
     [
     CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
     ]
    variants (modulo AC)
    1. $CA   = $CA.23
       $i    = $i.24
       $j    = $j.25
       $rootCA
             = $rootCA.27
       ca_sig
             = ca_sig.28
       pkCA  = pkCA.29
       pkRCA = pkRCA.30
       sn    = sn.31
       z     = verify(ca_sig.28,
                      <$rootCA.27, $CA.23, pkCA.29, 'pubKey-CA', sn.31, $i.24, $j.25>,
                      pkRCA.30)
    
    2. $CA   = $CA.48
       $i    = $i.49
       $j    = $j.50
       $rootCA
             = $rootCA.52
       ca_sig
             = sign(<$rootCA.52, $CA.48, pkCA.54, 'pubKey-CA', sn.56, $i.49, $j.50>,
                    x.94)
       pkCA  = pkCA.54
       pkRCA = pk(x.94)
       sn    = sn.56
       z     = true
  */

restriction externalCA_no_proof:
  "∀ rootCA CA ca_fields #t1.
    (UndocumentedIntermediateCA( rootCA, CA, ca_fields ) @ #t1) ⇒
    (¬(∃ #t0. (DocumentedCA( rootCA, CA, ca_fields ) @ #t0) ∧ (#t0 < #t1)))"
  // safety formula

rule (modulo E) GossipTransparencyCheck_Success:
   [
   ClientGossiped( $C, $M, $L, gossiped_session, $gossiped_proof_time,
                   fields, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
                   <<cert_fields, cert_sig>, 
                    <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
   ),
   AppendOnlyChecked( $M, gossiped_session, session ),
   MonitorInclusionVerified( $M, $L, fields, $time_of_proof_fetch, session,
                             <<cert_fields, cert_sig>, 
                              <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
   )
   ]
  --[
  STHGossipTransparencyCheck( $M, $L, fields, $CA,
                              <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                              gossiped_session
  ),
  CTGossipTransparencyCheckSuccess( $M, $L, fields, $CA,
                                    <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                                    gossiped_session
  ),
  San_GossipTransparencyCheck_Success( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) GossipTransparencyCheck_Failed:
   [
   ClientGossiped( $C, $M, $L, gossiped_session, $gossiped_proof_time,
                   fields, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
                   <<cert_fields, cert_sig>, 
                    <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
   ),
   AppendOnlyChecked( $M, gossiped_session, session ),
   MonitorInclusionFailed( $M, $L, fields,
                           <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                           $time_of_proof_fetch, session
   )
   ]
  --[
  ProofFetchAfterGossip( $gossiped_proof_time, $time_of_proof_fetch ),
  STHGossipTransparencyCheck( $M, $L, fields, $CA,
                              <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                              gossiped_session
  ),
  CTGossipTransparencyCheck_NotFound( $M, $L, fields, $CA,
                                      <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                                      gossiped_session
  ),
  San_GossipTransparencyCheck_Failed( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) GossipingCheck:
   [
   ClientGossiped( $C, $M, $L, gossiped_session, $gossiped_proof_time,
                   <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                   <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
                   <<cert_fields, cert_sig>, 
                    <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
   ),
   AppendOnlyChecked( $M, gossiped_session, session ),
   MonitorInspected( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time_of_proof_fetch,
                     session
   ),
   CCADBConsulted( $rootCA,
                   <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>
   ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  Eq( verify(cert_sig, cert_fields, pkCA), true ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  ProofFetchAfterGossip( $proof, $time_of_proof_fetch ),
  STHGossipCheck( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                  <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                  gossiped_session
  ),
  San_GossipingCheck( )
  ]->
   [ ]

  /*
  rule (modulo AC) GossipingCheck:
     [
     ClientGossiped( $C, $M, $L, gossiped_session, $gossiped_proof_time,
                     <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
                     <<cert_fields, cert_sig>, 
                      <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
     ),
     AppendOnlyChecked( $M, gossiped_session, session ),
     MonitorInspected( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                       <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time_of_proof_fetch,
                       session
     ),
     CCADBConsulted( $rootCA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>
     ),
     !Root_CA( $rootCA, pkRootCA )
     ]
    --[
    Eq( z, true ), Eq( z.1, true ),
    ProofFetchAfterGossip( $proof, $time_of_proof_fetch ),
    STHGossipCheck( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                    <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, session,
                    gossiped_session
    ),
    San_GossipingCheck( )
    ]->
     [ ]
    variants (modulo AC)
    1. $CA   = $CA.50
       $i0   = $i0.55
       $j0   = $j0.57
       $rootCA
             = $rootCA.59
       ca_sig
             = ca_sig.62
       cert_fields
             = cert_fields.63
       cert_sig
             = cert_sig.64
       pkCA  = pkCA.67
       pkRootCA
             = pkRootCA.68
       snCA  = snCA.71
       z     = verify(cert_sig.64, cert_fields.63, pkCA.67)
       z.1   = verify(ca_sig.62,
                      <$rootCA.59, $CA.50, pkCA.67, 'pubKey-CA', snCA.71, $i0.55, $j0.57>,
                      pkRootCA.68)
    
    2. $CA   = $CA.56
       $i0   = $i0.61
       $j0   = $j0.63
       $rootCA
             = $rootCA.65
       ca_sig
             = ca_sig.68
       cert_fields
             = cert_fields.69
       cert_sig
             = sign(cert_fields.69, x.109)
       pkCA  = pk(x.109)
       pkRootCA
             = pkRootCA.74
       snCA  = snCA.77
       z     = true
       z.1   = verify(ca_sig.68,
                      <$rootCA.65, $CA.56, pk(x.109), 'pubKey-CA', snCA.77, $i0.61, $j0.63>,
                      pkRootCA.74)
    
    3. $CA   = $CA.69
       $i0   = $i0.74
       $j0   = $j0.76
       $rootCA
             = $rootCA.78
       ca_sig
             = sign(<$rootCA.78, $CA.69, pkCA.86, 'pubKey-CA', snCA.90, $i0.74, $j0.76
                    >,
                    x.135)
       cert_fields
             = cert_fields.82
       cert_sig
             = cert_sig.83
       pkCA  = pkCA.86
       pkRootCA
             = pk(x.135)
       snCA  = snCA.90
       z     = verify(cert_sig.83, cert_fields.82, pkCA.86)
       z.1   = true
    
    4. $CA   = $CA.69
       $i0   = $i0.74
       $j0   = $j0.76
       $rootCA
             = $rootCA.78
       ca_sig
             = sign(<$rootCA.78, $CA.69, pk(x.133), 'pubKey-CA', snCA.90, $i0.74, 
                     $j0.76>,
                    x.135)
       cert_fields
             = cert_fields.82
       cert_sig
             = sign(cert_fields.82, x.133)
       pkCA  = pk(x.133)
       pkRootCA
             = pk(x.135)
       snCA  = snCA.90
       z     = true
       z.1   = true
  */

restriction proofFetchAfterGossip:
  "∀ before after #t1 #t2 #t.
    (((ProofFetchAfterGossip( before, after ) @ #t) ∧
      (Time( before ) @ #t1)) ∧
     (Time( after ) @ #t2)) ⇒
    (#t1 < #t2)"
  // safety formula

restriction rootCA_CA_distinct:
  "∀ rootCA CA #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (NonRoot_CA_Init( CA ) @ #t2)) ⇒
    (¬(rootCA = CA))"
  // safety formula

restriction rootCA_Logger_distinct:
  "∀ rootCA L #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (¬(rootCA = L))"
  // safety formula

restriction RootCA_Monitor_distinct:
  "∀ rootCA M #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(rootCA = M))"
  // safety formula

restriction CA_Logger_distinct:
  "∀ CA L #t1 #t2.
    ((NonRoot_CA_Init( CA ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (¬(CA = L))"
  // safety formula

restriction CA_Monitor_distinct:
  "∀ CA M #t1 #t2.
    ((NonRoot_CA_Init( CA ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(CA = M))"
  // safety formula

restriction Logger_Monitor_distinct:
  "∀ L M #t1 #t2.
    ((Logger_Registered( L ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(L = M))"
  // safety formula

restriction LoggersUnique:
  "∀ L #t1 #t2.
    ((Logger_Registered( L ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction CAsUnique:
  "∀ CA pk1 sk1 pk2 sk2 #t1 #t2.
    ((CA_Registered( CA, sk1, pk1 ) @ #t1) ∧
     (CA_Registered( CA, sk2, pk2 ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction eq:
  "∀ e1 e2 #t. (Eq( e1, e2 ) @ #t) ⇒ (e1 = e2)"
  // safety formula

restriction time_monotonicity:
  "∀ t #t1 #t3.
    (((Time( t ) @ #t1) ∧ (Time( t ) @ #t3)) ∧ (#t1 < #t3)) ⇒
    (∀ tp #t2.
      (((Time( tp ) @ #t2) ∧ (#t1 < #t2)) ∧ (#t2 < #t3)) ⇒ (tp = t))"
  // safety formula

restriction certStillValid:
  "∀ currTime valid_till #t1.
    ((Time( currTime ) @ #t1) ∧
     (CheckValidUntil( currTime, valid_till ) @ #t1)) ⇒
    (¬(∃ #t2. (#t2 < #t1) ∧ (Time( valid_till ) @ #t2)))"
  // safety formula

rule (modulo E) compromiseCA[color=#d40808]:
   [ !CA_s0( $CA, ~skCA, pk(~skCA), ca_fields, CA_sig ) ]
  --[
  CompromiseCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseCA( ), Time( $now )
  ]->
   [ Out( ~skCA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseRootCA[color=#d40808]:
   [ !Root_CA_s0( $CA, skCA, pkCA ) ]
  --[
  CompromiseRootCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseRootCA( ), Time( $now )
  ]->
   [ Out( skCA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseLogger[color=#d40808]:
   [ !Logger_s( $L, ~skL, pk(~skL) ) ]
  --[
  CompromiseLogger( $L ), CompromiseLoggerUniq( <$L, ~skL, pk(~skL)> ),
  Compromise( ), Corrupted( $L ), San_compromiseLogger( ), Time( $now )
  ]->
   [ Out( ~skL ), !Corrupted_Logger( $L, ~skL, pk(~skL) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseMonitor[color=#d40808]:
   [ !Monitor( $M ) ]
  --[
  Compromise( ), CompromiseMonitor( $M ), Corrupted( $M ),
  San_compromiseMonitor( ), Time( $now )
  ]->
   [ !St_bad_Monitor( $M ) ]

  /* has exactly the trivial AC variant */

