    (Asserts( rootCA.1, 'I signed this intermediate CA.', CA.1, ca_fields.1
     ) @ #t2.1)
   ⇒
    CA.1 = CA) ∧
  (∀ a #i. (Corrupted( a ) @ #i) ⇒ a = CA) ∧
  (∀ rootCA.1 M.1 CA.1 fields.1 ca_fields.1 #t0.1 #t1.1 #t2.1.
    (CTCheck( M.1, fields.1, CA.1, ca_fields.1 ) @ #t0.1) ∧
    (Asserts( M.1, 'Blame this CA.', CA.1, <fields.1, ca_fields.1>
     ) @ #t1.1) ∧
    (Asserts( 'CCADB', 'No root CA signed this CA.', CA.1,
              <ca_fields.1, rootCA.1>
     ) @ #t2.1)
   ⇒
    ⊥)"
*/
by sorry

