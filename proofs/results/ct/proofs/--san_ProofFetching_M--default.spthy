      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  MonitorObservesEntry( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                        <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>, sth, session
  ),
  RogueCert( $CA, <$CA, $subj, ke, 'pubKey', sn, $i, $j> ), Time( $now ),
  San_monitorFindsRogueCertificate_Sleep( )
