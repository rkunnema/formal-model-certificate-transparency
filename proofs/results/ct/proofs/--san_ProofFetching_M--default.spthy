rule (modulo E) ClientInitiatesAuditing:
   [
   In( ca_fields ), In( ca_sig ), In( pub_fields ), In( pub_sig ), In( sct )
   ]
  --[ Time( $now ), San_ClientInitiatesAuditing( ) ]->
   [ !TLS_to_M( $M, <<pub_fields, pub_sig>, ca_fields, ca_sig>, sct ) ]

  /* has exactly the trivial AC variant */

restriction Restr_ClientValidate_1:
  "∀ x #NOW x.1. (Restr_ClientValidate_1( x, x.1 ) @ #NOW) ⇒ (¬(x = x.1))"
  // safety formula

rule (modulo E) ClientValidate[color=#f2ce03]:
   [
   !Root_CA( $rootCA, pkRootCA ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   In( <$CA, $id, pkID, 'pubKey', sn, $i, $j, 
        <$L1, 'SCT', $sct1, sct1_sig>, $L2, 'SCT', $sct2, sct2_sig>
   ),
   In( pub_sig ), !Logger( $L1, pkL1 ), !Logger( $L2, pkL2 )
   ]
  --[
  BrowserAcceptsChain( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                       $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $L2
  ),
  BrowserAcceptsChainTimes( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                            $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $sct1
  ),
  BrowserAcceptsChainTimes( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                            $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L2, $sct2
  ),
  Eq( verify(pub_sig,
             <$CA, $id, pkID, 'pubKey', sn, $i, $j, <$L1, 'SCT', $sct1, sct1_sig>, 
              $L2, 'SCT', $sct2, sct2_sig>,
             pkCA),
      true
  ),
  Eq( verify(sct1_sig, <$L1, 'SCT', $sct1, $CA, $id, pkID, sn, $i, $j>,
             pkL1),
      true
  ),
  Eq( verify(sct2_sig, <$L2, 'SCT', $sct2, $CA, $id, pkID, sn, $i, $j>,
             pkL2),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  CheckValidUntil( $now, $j ), CheckValidUntil( $now, $j0 ), Time( $now ),
  San_ClientValidate( ), Restr_ClientValidate_1( $L1, $L2 )
  ]->
   [
   !BAccept_State( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                   <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $sct1, $L2, $sct2
   )
   ]

  /*
  rule (modulo AC) ClientValidate[color=#f2ce03]:
     [
     !Root_CA( $rootCA, pkRootCA ),
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
     In( <$CA, $id, pkID, 'pubKey', sn, $i, $j, 
          <$L1, 'SCT', $sct1, sct1_sig>, $L2, 'SCT', $sct2, sct2_sig>
     ),
     In( pub_sig ), !Logger( $L1, pkL1 ), !Logger( $L2, pkL2 )
     ]
    --[
    BrowserAcceptsChain( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                         $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $L2
    ),
    BrowserAcceptsChainTimes( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                              $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $sct1
    ),
    BrowserAcceptsChainTimes( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                              $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L2, $sct2
    ),
    Eq( z, true ), Eq( z.1, true ), Eq( z.2, true ), Eq( z.3, true ),
    CheckValidUntil( $now, $j ), CheckValidUntil( $now, $j0 ), Time( $now ),
    San_ClientValidate( ), Restr_ClientValidate_1( $L1, $L2 )
    ]->
     [
     !BAccept_State( $CA, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $L1, $sct1, $L2, $sct2
     )
     ]
    variants (modulo AC)
     1. $CA   = $CA.54
        $L1   = $L1.55
        $L2   = $L2.56
        $i    = $i.57
        $i0   = $i0.58
        $id   = $id.59
        $j    = $j.60
        $j0   = $j0.61
        $rootCA
              = $rootCA.63
        $sct1 = $sct1.64
        $sct2 = $sct2.65
        ca_sig
              = ca_sig.66
        pkCA  = pkCA.67
        pkID  = pkID.68
        pkL1  = pkL1.69
        pkL2  = pkL2.70
        pkRootCA
              = pkRootCA.71
        pub_sig
              = pub_sig.72
        sct1_sig
              = sct1_sig.73
        sct2_sig
              = sct2_sig.74
        sn    = sn.75
        snCA  = snCA.76
        z     = verify(pub_sig.72,
                       <$CA.54, $id.59, pkID.68, 'pubKey', sn.75, $i.57, $j.60, 
                        <$L1.55, 'SCT', $sct1.64, sct1_sig.73>, $L2.56, 'SCT', $sct2.65, 
                        sct2_sig.74>,
