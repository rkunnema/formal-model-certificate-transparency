  FetchLogSnapshotTime( $M, $L, ~session, $now ), Time( $now ),
  San_ProofFetching_M( )
  ]->
   [ TLS_M_to_L( $M, $L, ~session, $now ) ]

  /* has exactly the trivial AC variant */

