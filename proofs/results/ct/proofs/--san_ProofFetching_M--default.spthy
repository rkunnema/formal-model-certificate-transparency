                   <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>
    ),
    San_ChainValidator_Invalid( ), Restr_ChainValidator_Invalid_1( z, z.1 )
    ]->
     [ ]
    variants (modulo AC)
    1. $CA   = $CA.33
       $i    = $i.34
       $i0   = $i0.35
       $j    = $j.36
       $j0   = $j0.37
       $rootCA
             = $rootCA.38
       $subj = $subj.39
       ca_sig
             = ca_sig.40
       cert_sig
             = cert_sig.41
       ke    = ke.42
       pkCA  = pkCA.43
       pkRootCA
             = pkRootCA.44
       sn    = sn.45
       snCA  = snCA.46
       z     = verify(cert_sig.41,
                      <$CA.33, $subj.39, ke.42, 'pre-cert', sn.45, $i.34, $j.36>, pkCA.43)
       z.1   = verify(ca_sig.40,
                      <$rootCA.38, $CA.33, pkCA.43, 'pubKey-CA', snCA.46, $i0.35, $j0.37>,
                      pkRootCA.44)
    
    2. $CA   = $CA.47
       $i    = $i.48
       $i0   = $i0.49
       $j    = $j.50
       $j0   = $j0.51
       $rootCA
             = $rootCA.52
       $subj = $subj.53
       ca_sig
             = sign(<$rootCA.52, $CA.47, pkCA.57, 'pubKey-CA', snCA.60, $i0.49, $j0.51
                    >,
                    x.92)
       cert_sig
             = cert_sig.55
       ke    = ke.56
       pkCA  = pkCA.57
       pkRootCA
             = pk(x.92)
       sn    = sn.59
       snCA  = snCA.60
       z     = verify(cert_sig.55,
                      <$CA.47, $subj.53, ke.56, 'pre-cert', sn.59, $i.48, $j.50>, pkCA.57)
       z.1   = true
    
    3. $CA   = $CA.47
       $i    = $i.48
       $i0   = $i0.49
       $j    = $j.50
       $j0   = $j0.51
       $rootCA
             = $rootCA.52
       $subj = $subj.53
       ca_sig
             = sign(<$rootCA.52, $CA.47, pk(x.90), 'pubKey-CA', snCA.60, $i0.49, 
                     $j0.51>,
                    x.92)
       cert_sig
             = sign(<$CA.47, $subj.53, ke.56, 'pre-cert', sn.59, $i.48, $j.50>, x.90)
       ke    = ke.56
       pkCA  = pk(x.90)
       pkRootCA
             = pk(x.92)
       sn    = sn.59
       snCA  = snCA.60
       z     = true
       z.1   = true
    
    4. $CA   = $CA.48
       $i    = $i.49
       $i0   = $i0.50
       $j    = $j.51
       $j0   = $j0.52
       $rootCA
             = $rootCA.53
       $subj = $subj.54
       ca_sig
             = ca_sig.55
       cert_sig
             = sign(<$CA.48, $subj.54, ke.57, 'pre-cert', sn.60, $i.49, $j.51>, x.94)
       ke    = ke.57
