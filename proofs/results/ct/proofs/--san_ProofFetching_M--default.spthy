restriction only_existing_log_ids:
  "∀ L idR log_id time sth session #t1.
    (LoggerPresentsView( L, idR, log_id, time, sth, session ) @ #t1) ⇒
    (∃ #t0. (StartedLog( L, log_id ) @ #t0) ∧ (#t0 < #t1))"

rule (modulo E) ParticipantFindsInclusionViolation[color=#e65208]:
   [
   !TLS_L_to_P( $L, $P, $snapshot, sth, session, $time ),
   !Logger( $L, pkL ), In( <$CA, $id, pkID, 'pubKey', sn, $i, $j> ),
   In( <ca_fields, ca_sig> )
   ]
  --[
  Asserts( $P, 'This loggers log currently does not include these fields.',
           $L, <<$CA, $id, pkID, 'pubKey', sn, $i, $j>, session>
  ),
  InclusionProofFails( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                       <ca_fields, ca_sig>, sth, session
  ),
  Time( $now ), San_ParticipantFindsInclusionViolation( )
  ]->
   [
   InclusionFalsified( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                       $time, session, ca_fields
   )
   ]

  /* has exactly the trivial AC variant */

restriction inclusionProofFails:
  "∀ IdFetcher L fields ca_cert sth session #t1.
    (InclusionProofFails( IdFetcher, L, fields, ca_cert, sth, session
     ) @ #t1) ⇒
    (∃ log_id time #t0.
      ((LoggerPresentsView( L, IdFetcher, log_id, time, sth, session ) @ #t0) ∧
       (#t0 < #t1)) ∧
      (¬(∃ ca_cert.1 different_time chain #t.
          ((LoggerComputesAddLog( L, log_id, fields, ca_cert.1, chain,
                                  different_time
            ) @ #t) ∧
           (¬(time = different_time))) ∧
          (#t < #t0))))"

rule (modulo E) ParticipantVerifiesInclusion[color=#c1ff3c]:
   [
   !TLS_L_to_P( $L, $P, $snapshot, sth, session, $time ),
   !Logger( $L, pkL ), In( <$CA, $id, pkID, 'pubKey', sn, $i, $j> ),
   In( <ca_fields, ca_sig> ), In( chain )
   ]
  --[
  InclusionProofSucceeds( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                          <ca_fields, ca_sig>, chain, sth, session
  ),
  Asserts( $P, 'This loggers log currently includes these fields.', $L,
           <<$CA, $id, pkID, 'pubKey', sn, $i, $j>, session>
  ),
  LContains( $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j> ), Time( $now ),
  San_ParticipantVerifiesInclusion( )
  ]->
   [
   InclusionVerified( $P, $L, <$CA, $id, pkID, 'pubKey', sn, $i, $j>, $time,
                      session, ca_fields
   )
   ]

  /* has exactly the trivial AC variant */

restriction inclusionProofWorks:
  "∀ IdFetcher L fields ca_cert chain sth session #t5.
    (InclusionProofSucceeds( IdFetcher, L, fields, ca_cert, chain, sth,
                             session
     ) @ #t5) ⇒
    (∃ id log_id time #t2.
      ((LoggerPresentsView( L, id, log_id, time, sth, session ) @ #t2) ∧
       (#t2 < #t5)) ∧
      (∃ different_time #t.
        ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
          ) @ #t) ∧
         (¬(time = different_time))) ∧
        (#t < #t2)))"

rule (modulo E) ConsultDocumentation_Success:
   [
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRCA ),
   !CA_Documentation( $rootCA, $CA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, ca_sig
   )
   ]
  --[
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, pkRCA),
      true
  ),
  Asserts( $rootCA, 'I signed this intermediate CA.', $CA,
           <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  ExternalCheckCCADB( $rootCA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Time( $now ), San_ConsultDocumentation_Success( )
  ]->
   [
   CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
   ]

  /*
  rule (modulo AC) ConsultDocumentation_Success:
     [
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
     !Root_CA( $rootCA, pkRCA ),
     !CA_Documentation( $rootCA, $CA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, ca_sig
     )
     ]
    --[
    Eq( z, true ),
    Asserts( $rootCA, 'I signed this intermediate CA.', $CA,
             <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    ExternalCheckCCADB( $rootCA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Time( $now ), San_ConsultDocumentation_Success( )
    ]->
     [
     CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
     ]
    variants (modulo AC)
    1. $CA   = $CA.21
       $i    = $i.22
       $j    = $j.23
       $rootCA
             = $rootCA.25
       ca_sig
             = ca_sig.26
       pkCA  = pkCA.27
       pkRCA = pkRCA.28
       sn    = sn.29
       z     = verify(ca_sig.26,
                      <$rootCA.25, $CA.21, pkCA.27, 'pubKey-CA', sn.29, $i.22, $j.23>,
                      pkRCA.28)
    
    2. $CA   = $CA.32
       $i    = $i.33
       $j    = $j.34
       $rootCA
             = $rootCA.36
       ca_sig
             = sign(<$rootCA.36, $CA.32, pkCA.38, 'pubKey-CA', sn.40, $i.33, $j.34>,
                    x.62)
       pkCA  = pkCA.38
       pkRCA = pk(x.62)
       sn    = sn.40
       z     = true
  */

rule (modulo E) ConsultDocumentation_Fails:
   [
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
   !Root_CA( $rootCA, pkRCA )
   ]
  --[
  UndocumentedIntermediateCA( $rootCA, $CA,
                              <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Asserts( 'CCADB', 'No root CA signed this CA.', $CA,
           <<$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, $rootCA>
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, pkRCA),
      true
  ),
  ExternalCheckCCADB( $rootCA,
                      <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
  ),
  Time( $now ), San_ConsultDocumentation_Fails( )
  ]->
   [
   CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
   ]

  /*
  rule (modulo AC) ConsultDocumentation_Fails:
     [
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> ), In( ca_sig ),
     !Root_CA( $rootCA, pkRCA )
     ]
    --[
    UndocumentedIntermediateCA( $rootCA, $CA,
                                <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Asserts( 'CCADB', 'No root CA signed this CA.', $CA,
             <<$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>, $rootCA>
    ),
    Eq( z, true ),
    ExternalCheckCCADB( $rootCA,
                        <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j>
    ),
    Time( $now ), San_ConsultDocumentation_Fails( )
    ]->
     [
     CCADBConsulted( $rootCA, <$rootCA, $CA, pkCA, 'pubKey-CA', sn, $i, $j> )
     ]
    variants (modulo AC)
    1. $CA   = $CA.23
       $i    = $i.24
       $j    = $j.25
       $rootCA
             = $rootCA.27
       ca_sig
             = ca_sig.28
       pkCA  = pkCA.29
       pkRCA = pkRCA.30
       sn    = sn.31
       z     = verify(ca_sig.28,
                      <$rootCA.27, $CA.23, pkCA.29, 'pubKey-CA', sn.31, $i.24, $j.25>,
                      pkRCA.30)
    
    2. $CA   = $CA.48
       $i    = $i.49
       $j    = $j.50
       $rootCA
             = $rootCA.52
       ca_sig
             = sign(<$rootCA.52, $CA.48, pkCA.54, 'pubKey-CA', sn.56, $i.49, $j.50>,
                    x.94)
       pkCA  = pkCA.54
       pkRCA = pk(x.94)
       sn    = sn.56
       z     = true
  */

restriction externalCA_no_proof:
  "∀ rootCA CA ca_fields #t1.
    (UndocumentedIntermediateCA( rootCA, CA, ca_fields ) @ #t1) ⇒
    (¬(∃ #t0. (DocumentedCA( rootCA, CA, ca_fields ) @ #t0) ∧ (#t0 < #t1)))"
  // safety formula

restriction Restr_MonitorCheck_Found_CCADB_1:
  "∀ x #NOW x.1 x.2 x.3.
    (Restr_MonitorCheck_Found_CCADB_1( x, x.1, x.2, x.3 ) @ #NOW) ⇒
    ((x = x.1) ∨ (x.2 = x.3))"
  // safety formula

rule (modulo E) MonitorCheck_Found_CCADB:
   [
   !BAccept_State( $CA, fields, ca_fields, $L1, $sct1, $L2, $sct2 ),
   MonitorFoundCert( $M, $L, fields, $CA, ca_fields, $time_of_proof_fetch,
                     session
   ),
   CCADBConsulted( $rootCA, ca_fields )
   ]
  --[
  CTCheck( $M, fields, $CA, ca_fields ), San_MonitorCheck_Found( ),
  Restr_MonitorCheck_Found_CCADB_1( $L1, $L, $L2, $L )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) MonitorCheck_NotFound_CCADB:
   [
   !BAccept_State( $CA, fields, ca_fields, $L1, $sct1, $L2, $sct2 ),
   MonitorCouldNotFindCert( $M, fields, $L1, $CA, ca_fields, $proof1,
                            session1
   ),
   MonitorCouldNotFindCert( $M, fields, $L2, $CA, ca_fields, $proof2,
                            session2
   ),
   CCADBConsulted( $rootCA, ca_fields )
   ]
  --[
  CTCheck( $M, fields, $CA, ca_fields ), MMD_passed( $sct1, $proof1 ),
  MMD_passed( $sct2, $proof2 ), San_MonitorCheck_NotFound( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) TransparencyCheck_Success:
   [ InclusionVerified( $P, $L, fields, $proof_time, session, ca_fields ) ]
  --[
  CTTransparencyCheckSession( $L, fields, session ),
  CTTransparencyCheckTime( $L, fields, session, $proof_time ),
  CTTransparencyCheck( $L, fields ),
  CTTransparencyCheckSuccess( $L, fields ),
  San_TransparencyCheck_Success( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) TransparencyCheck_Failed:
   [ InclusionFalsified( $P, $L, fields, $proof_time, session, ca_fields ) ]
  --[
  CTTransparencyCheckSession( $L, fields, session ),
  CTTransparencyCheckTime( $L, fields, session, $proof_time ),
  CTTransparencyCheck( $L, fields ), San_TransparencyCheck_Failed( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

restriction mmd_passed:
  "∀ before after #t2 #t1 #t0.
    (((MMD_passed( before, after ) @ #t2) ∧ (Time( before ) @ #t0)) ∧
     (Time( after ) @ #t1)) ⇒
    (((#t0 < #t1) ∧ (#t1 < #t2)) ∧ (¬(before = after)))"
  // safety formula

restriction rootCA_CA_distinct:
  "∀ rootCA CA #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (NonRoot_CA_Init( CA ) @ #t2)) ⇒
    (¬(rootCA = CA))"
  // safety formula

restriction rootCA_Logger_distinct:
  "∀ rootCA L #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (¬(rootCA = L))"
  // safety formula

restriction RootCA_Monitor_distinct:
  "∀ rootCA M #t1 #t2.
    ((Root_CA_Init( rootCA ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(rootCA = M))"
  // safety formula

restriction CA_Logger_distinct:
  "∀ CA L #t1 #t2.
    ((NonRoot_CA_Init( CA ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (¬(CA = L))"
  // safety formula

restriction CA_Monitor_distinct:
  "∀ CA M #t1 #t2.
    ((NonRoot_CA_Init( CA ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(CA = M))"
  // safety formula

restriction Logger_Monitor_distinct:
  "∀ L M #t1 #t2.
    ((Logger_Registered( L ) @ #t1) ∧ (Monitor_Registered( M ) @ #t2)) ⇒
    (¬(L = M))"
  // safety formula

restriction LoggersUnique:
  "∀ L #t1 #t2.
    ((Logger_Registered( L ) @ #t1) ∧ (Logger_Registered( L ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction CAsUnique:
  "∀ CA pk1 sk1 pk2 sk2 #t1 #t2.
    ((CA_Registered( CA, sk1, pk1 ) @ #t1) ∧
     (CA_Registered( CA, sk2, pk2 ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction eq:
  "∀ e1 e2 #t. (Eq( e1, e2 ) @ #t) ⇒ (e1 = e2)"
  // safety formula

restriction time_monotonicity:
  "∀ t #t1 #t3.
    (((Time( t ) @ #t1) ∧ (Time( t ) @ #t3)) ∧ (#t1 < #t3)) ⇒
    (∀ tp #t2.
      (((Time( tp ) @ #t2) ∧ (#t1 < #t2)) ∧ (#t2 < #t3)) ⇒ (tp = t))"
  // safety formula

restriction certStillValid:
  "∀ currTime valid_till #t1.
    ((Time( currTime ) @ #t1) ∧
     (CheckValidUntil( currTime, valid_till ) @ #t1)) ⇒
    (¬(∃ #t2. (#t2 < #t1) ∧ (Time( valid_till ) @ #t2)))"
  // safety formula

rule (modulo E) compromiseCA[color=#d40808]:
   [ !CA_s0( $CA, ~skCA, pk(~skCA), ca_fields, CA_sig ) ]
  --[
  CompromiseCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseCA( ), Time( $now )
  ]->
   [ Out( ~skCA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseRootCA[color=#d40808]:
   [ !Root_CA_s0( $CA, skCA, pkCA ) ]
  --[
  CompromiseRootCA( $CA ), Compromise( ), Corrupted( $CA ),
  San_compromiseRootCA( ), Time( $now )
  ]->
   [ Out( skCA ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseLogger[color=#d40808]:
   [ !Logger_s( $L, ~skL, pk(~skL) ) ]
  --[
  CompromiseLogger( $L ), CompromiseLoggerUniq( <$L, ~skL, pk(~skL)> ),
  Compromise( ), Corrupted( $L ), San_compromiseLogger( ), Time( $now )
  ]->
   [ Out( ~skL ), !Corrupted_Logger( $L, ~skL, pk(~skL) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) compromiseMonitor[color=#d40808]:
   [ !Monitor( $M ) ]
  --[
  Compromise( ), CompromiseMonitor( $M ), Corrupted( $M ),
  San_compromiseMonitor( ), Time( $now )
  ]->
   [ !St_bad_Monitor( $M ) ]

  /* has exactly the trivial AC variant */

