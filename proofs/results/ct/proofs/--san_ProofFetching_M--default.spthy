predicate: ChainVisible( Logger, fields, ca_cert, log_id, #time, sth_time )<=>∃ chain different_time #t.
 ((LoggerComputesAddLog( Logger, log_id, fields, ca_cert, chain,
                         different_time
   ) @ #t) ∧
  (¬(sth_time = different_time))) ∧
 (#t < #time)

predicate: NoChainVisible( Logger, fields, log_id, #time, sth_time )<=>(¬(∃ different_time #t.
    ((LoggerComputesAddLogFields( Logger, log_id, fields,
                                  different_time
      ) @ #t) ∧
     (¬(sth_time = different_time))) ∧
    (#t < #time))) ∨
((∀ ca_cert different_time chain #t2 #t.
   ((((LoggerComputesAddLog( Logger, log_id, fields, ca_cert, chain,
                             different_time
       ) @ #t) ∧
      (¬(sth_time = different_time))) ∧
     (#t < #time)) ∧
    (ChainCheck( chain ) @ #t2)) ⇒
   (ChainInvalid( chain ) @ #t2)) ∧
 (∀ different_time ca_cert chain #t.
   ((LoggerComputesAddLog( Logger, log_id, fields, ca_cert, chain,
                           different_time
     ) @ #t) ∧
    (#t < #time)) ⇒
   (∃ #t2. ChainCheck( chain ) @ #t2)))

restriction logExplorationSucceeds:
  "∀ M L fields ca_cert sth session #t5.
    (MonitorObservesEntry( M, L, fields, ca_cert, sth, session ) @ #t5) ⇒
    (∃ log_id time #t2.
      ((LoggerPresentsView( L, M, log_id, time, sth, session ) @ #t2) ∧
       (#t2 < #t5)) ∧
      (∃ chain different_time #t.
        ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
          ) @ #t) ∧
         (¬(time = different_time))) ∧
        (#t < #t2)))"

restriction logExplorationFails:
  "∀ M L fields sth session #t1.
    (NothingObserved( M, L, fields, sth, session ) @ #t1) ⇒
    (∃ log_id time #t0.
      ((LoggerPresentsView( L, M, log_id, time, sth, session ) @ #t0) ∧
       (#t0 < #t1)) ∧
      ((¬(∃ different_time #t.
           ((LoggerComputesAddLogFields( L, log_id, fields, different_time ) @ #t) ∧
            (¬(time = different_time))) ∧
           (#t < #t0))) ∨
       ((∀ ca_cert different_time chain #t2 #t.
          ((((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain,
                                    different_time
              ) @ #t) ∧
             (¬(time = different_time))) ∧
            (#t < #t0)) ∧
           (ChainCheck( chain ) @ #t2)) ⇒
          (ChainInvalid( chain ) @ #t2)) ∧
        (∀ different_time ca_cert chain #t.
          ((LoggerComputesAddLog( L, log_id, fields, ca_cert, chain, different_time
            ) @ #t) ∧
           (#t < #t0)) ⇒
          (∃ #t2. ChainCheck( chain ) @ #t2)))))"

rule (modulo E) monitorFindsRogueCertificate[color=#f3d664]:
   [
   !LoggerDict( $M, $L ), !TrackSubject( $M, su ),
   In( <$CA, $subj, ke, 'pubKey', sn, $i, $j, sct1, sct2> ), In( cert_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time ),
   !Root_CA( $rootCA, pkRootCA )
   ]
  --[
  Eq( verify(cert_sig, <$CA, $subj, ke, 'pubKey', sn, $i, $j, sct1, sct2>,
             pkCA),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  MonitorObservesEntry( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                        <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>, sth, session
  ),
  RogueCert( $CA, <$CA, $subj, ke, 'pubKey', sn, $i, $j> ),
  Asserts( $M, 'Blame this CA.', $CA,
           <<$CA, $subj, ke, 'pubKey', sn, $i, $j>, $rootCA, $CA, pkCA, 
            'pubKey-CA', snCA, $i0, $j0>
  ),
  Time( $now ), San_monitorFindsRogueCertificate( )
  ]->
   [
   MonitorFoundCert( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                     <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
   )
   ]

  /*
  rule (modulo AC) monitorFindsRogueCertificate[color=#f3d664]:
     [
     !LoggerDict( $M, $L ), !TrackSubject( $M, su ),
     In( <$CA, $subj, ke, 'pubKey', sn, $i, $j, sct1, sct2> ), In( cert_sig ),
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
     !TLS_L_to_M( $L, $M, $snapshot, sth, session, $time ),
     !Root_CA( $rootCA, pkRootCA )
     ]
    --[
    Eq( z, true ), Eq( z.1, true ),
    MonitorObservesEntry( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>,
                          <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>, sth, session
    ),
    RogueCert( $CA, <$CA, $subj, ke, 'pubKey', sn, $i, $j> ),
    Asserts( $M, 'Blame this CA.', $CA,
             <<$CA, $subj, ke, 'pubKey', sn, $i, $j>, $rootCA, $CA, pkCA, 
              'pubKey-CA', snCA, $i0, $j0>
    ),
    Time( $now ), San_monitorFindsRogueCertificate( )
    ]->
     [
     MonitorFoundCert( $M, $L, <$CA, $subj, ke, 'pubKey', sn, $i, $j>, $CA,
                       <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, $time, session
     )
     ]
    variants (modulo AC)
    1. $CA   = $CA.51
       $i    = $i.54
       $i0   = $i0.55
       $j    = $j.56
       $j0   = $j0.57
       $rootCA
             = $rootCA.59
       $subj = $subj.61
       ca_sig
             = ca_sig.63
       cert_sig
             = cert_sig.64
       ke    = ke.65
       pkCA  = pkCA.66
       pkRootCA
             = pkRootCA.67
       sct1  = sct1.68
       sct2  = sct2.69
       sn    = sn.71
       snCA  = snCA.72
       z     = verify(cert_sig.64,
                      <$CA.51, $subj.61, ke.65, 'pubKey', sn.71, $i.54, $j.56, sct1.68, sct2.69
                      >,
                      pkCA.66)
       z.1   = verify(ca_sig.63,
                      <$rootCA.59, $CA.51, pkCA.66, 'pubKey-CA', snCA.72, $i0.55, $j0.57>,
                      pkRootCA.67)
    
    2. $CA   = $CA.102
       $i    = $i.105
       $i0   = $i0.106
       $j    = $j.107
       $j0   = $j0.108
       $rootCA
             = $rootCA.110
       $subj = $subj.112
       ca_sig
             = sign(<$rootCA.110, $CA.102, pkCA.117, 'pubKey-CA', snCA.123, $i0.106, 
                     $j0.108>,
                    x.202)
       cert_sig
             = cert_sig.115
       ke    = ke.116
       pkCA  = pkCA.117
       pkRootCA
             = pk(x.202)
       sct1  = sct1.119
       sct2  = sct2.120
       sn    = sn.122
       snCA  = snCA.123
       z     = verify(cert_sig.115,
                      <$CA.102, $subj.112, ke.116, 'pubKey', sn.122, $i.105, $j.107, sct1.119, 
                       sct2.120>,
