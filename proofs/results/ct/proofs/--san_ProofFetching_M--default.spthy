rule (modulo E) Logger_Init[color=#08a358]:
   [ Fr( ~skL ) ]
  --[ Logger_Registered( $L ), Time( $now ), San_Logger_Init( ) ]->
   [ !Logger_s( $L, ~skL, pk(~skL) ), !Logger( $L, pk(~skL) ) ]

  /* has exactly the trivial AC variant */

rule (modulo E) Start_Log[color=#08a358]:
   [ !Logger_s( $L, ~skL, pk(~skL) ) ]
  --[
  StartedLog( $L, $log_id ), HonestStartedLog( $L, $log_id ), Time( $now ),
  San_Start_Log( )
  ]->
   [ !Log( $L, $log_id ) ]

  /* has exactly the trivial AC variant */

restriction honestStartLogOnlyOnce:
  "∀ L lid1 lid2 #t1 #t2.
    ((HonestStartedLog( L, lid1 ) @ #t1) ∧
     (HonestStartedLog( L, lid2 ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

restriction uniqueLogId:
  "∀ L log_id #t1 #t2.
    ((StartedLog( L, log_id ) @ #t1) ∧ (StartedLog( L, log_id ) @ #t2)) ⇒
    (#t1 = #t2)"
  // safety formula

rule (modulo E) Start_Log_malicious[color=#d83b0b]:
   [ !Corrupted_Logger( $L, ~skL, pk(~skL) ) ]
  --[ StartedLog( $L, $log_id ), Time( $now ), San_Start_Log_malicious( )
  ]->
   [ ]

  /* has exactly the trivial AC variant */

rule (modulo E) add_preC_to_log[color=#08a358]:
   [
   In( <$CA, $id, pkID, 'pre-cert', sn, $i, $j> ), In( preC_sig ),
   In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
   !Logger_s( $L, skL, pk(skL) ), !Root_CA( $rootCA, pkRootCA ),
   !Log( $L, $log_id )
   ]
  --[
  Eq( verify(preC_sig, <$CA, $id, pkID, 'pre-cert', sn, $i, $j>, pkCA),
      true
  ),
  Eq( verify(ca_sig, <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>,
             pkRootCA),
      true
  ),
  LoggerComputesAddLogFields( $L, $log_id,
                              <$CA, $id, pkID, 'pubKey', sn, $i, $j>, $now
  ),
  LoggerComputesAddLog( $L, $log_id,
                        <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                        <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        <<<$CA, $id, pkID, 'pre-cert', sn, $i, $j>, preC_sig>, 
                         <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                        $now
  ),
  LoggerAsserts( $L,
                 <$L, 'SCT', $now, 
                  sign(<$L, 'SCT', $now, $CA, $id, pkID, sn, $i, $j>, skL)>
  ),
  CheckValidUntil( $now, $j ), Time( $now ), San_add_preC_to_log( )
  ]->
   [
   Out( <$L, 'SCT', $now, 
         sign(<$L, 'SCT', $now, $CA, $id, pkID, sn, $i, $j>, skL)>
   )
   ]

  /*
  rule (modulo AC) add_preC_to_log[color=#08a358]:
     [
     In( <$CA, $id, pkID, 'pre-cert', sn, $i, $j> ), In( preC_sig ),
     In( <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0> ), In( ca_sig ),
     !Logger_s( $L, skL, pk(skL) ), !Root_CA( $rootCA, pkRootCA ),
     !Log( $L, $log_id )
     ]
    --[
    Eq( z, true ), Eq( z.1, true ),
    LoggerComputesAddLogFields( $L, $log_id,
                                <$CA, $id, pkID, 'pubKey', sn, $i, $j>, $now
    ),
    LoggerComputesAddLog( $L, $log_id,
                          <$CA, $id, pkID, 'pubKey', sn, $i, $j>,
                          <<$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                          <<<$CA, $id, pkID, 'pre-cert', sn, $i, $j>, preC_sig>, 
                           <$rootCA, $CA, pkCA, 'pubKey-CA', snCA, $i0, $j0>, ca_sig>,
                          $now
    ),
    LoggerAsserts( $L,
                   <$L, 'SCT', $now, 
                    sign(<$L, 'SCT', $now, $CA, $id, pkID, sn, $i, $j>, skL)>
    ),
    CheckValidUntil( $now, $j ), Time( $now ), San_add_preC_to_log( )
    ]->
     [
     Out( <$L, 'SCT', $now, 
           sign(<$L, 'SCT', $now, $CA, $id, pkID, sn, $i, $j>, skL)>
     )
     ]
    variants (modulo AC)
    1. $CA   = $CA.42
       $i    = $i.44
       $i0   = $i0.45
       $id   = $id.46
       $j    = $j.47
       $j0   = $j0.48
       $rootCA
             = $rootCA.51
       ca_sig
             = ca_sig.52
       pkCA  = pkCA.53
       pkID  = pkID.54
       pkRootCA
             = pkRootCA.55
       preC_sig
             = preC_sig.56
       sn    = sn.58
       snCA  = snCA.59
       z     = verify(preC_sig.56,
                      <$CA.42, $id.46, pkID.54, 'pre-cert', sn.58, $i.44, $j.47>, pkCA.53)
       z.1   = verify(ca_sig.52,
                      <$rootCA.51, $CA.42, pkCA.53, 'pubKey-CA', snCA.59, $i0.45, $j0.48>,
                      pkRootCA.55)
    
    2. $CA   = $CA.108
       $i    = $i.110
       $i0   = $i0.111
       $id   = $id.112
       $j    = $j.113
       $j0   = $j0.114
       $rootCA
             = $rootCA.117
       ca_sig
             = ca_sig.118
       pkCA  = pk(x.214)
       pkID  = pkID.120
       pkRootCA
             = pkRootCA.121
       preC_sig
