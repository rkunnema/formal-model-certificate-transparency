lemma sct_auth:
  all-traces
  "∀ l1 l2 rootCA ca_fields CA fields #t.
    (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, l1, l2 ) @ #t) ⇒
    (((∃ lid1 lid2 time1 time2 #lt1 #lt2.
        (((LoggerComputesAddLogFields( l1, lid1, fields, time1 ) @ #lt1) ∧
          (LoggerComputesAddLogFields( l2, lid2, fields, time2 ) @ #lt2)) ∧
         (#lt1 < #t)) ∧
        (#lt2 < #t)) ∨
      (∃ #c1. CompromiseLogger( l1 ) @ #c1)) ∨
     (∃ #c2. CompromiseLogger( l2 ) @ #c2))"
/*
guarded formula characterizing all counter-examples:
"∃ l1 l2 rootCA ca_fields CA fields #t.
  (BrowserAcceptsChain( CA, fields, rootCA, ca_fields, l1, l2 ) @ #t)
 ∧
  (∀ lid1 lid2 time1 time2 #lt1 #lt2.
    (LoggerComputesAddLogFields( l1, lid1, fields, time1 ) @ #lt1) ∧
    (LoggerComputesAddLogFields( l2, lid2, fields, time2 ) @ #lt2)
   ⇒
    ((¬(#lt1 < #t)) ∨ (¬(#lt2 < #t)))) ∧
  (∀ #c1. (CompromiseLogger( l1 ) @ #c1) ⇒ ⊥) ∧
  (∀ #c2. (CompromiseLogger( l2 ) @ #c2) ⇒ ⊥)"
*/
by sorry

lemma transparency:
