/* Authenticity */

// counterexample to authenticity
lemma authenticity:
    exists-trace
    "Ex L1 L2 rootCA ca_fields CA fields #j.
        BrowserAcceptsChain(CA, fields, rootCA, ca_fields, L1, L2)@j 
        & not (Ex #i. GroundTruth(CA, fields)@i & #i < #j)"


/* ---------------------
        TRANSPARENCY
   --------------------- */

/* 
The auditing mechanism alone does not enhance transparency but we will see below that the audited material can be used to enhance accountable transparency
*/
/* falsified */
lemma transparency_SCT_Auditing:
    "All CA fields rootCA ca_fields L1 L2 L #t1 #t2.
        BrowserAcceptsChain(CA, fields, rootCA, ca_fields, L1, L2)@t1
        & ((L = L1) | (L = L2))
        & SCTAuditTransparencyCheck(L, fields)@t2
        & #t1 < #t2
            ==>
            SCTAuditTransparencyCheckSuccess(L, fields)@t2
    "

/* ------------------------
    ACCOUNTABILITY LEMMAS
   ------------------------ */

/* ----- Accountable Transparency ----- */

/*
In this variant, the monitor performs an audit where it got the SCT externally (e.g., from a client). Then, it fetches a log view and runs the usual inclusion check. If the monitor cannot find the certificate, the logger is blamed.
*/
test audit_inclusionViol:
"Ex M fields session #t #t1.
  Asserts(M,'This loggers log currently does not include these fields.',L,<fields,session>)@t
& SCTAuditTransparencyCheckSession(L,fields,session)@t1"

/* 
Result: autoprovable
The monitor knows about the certificate thanks to the audited certificate. If after the given timestamp the certificate is still not included, that allows easy blaming as done as part of the SCTAuditTransparencyCheck.
*/
lemma T_Audit:
    audit_inclusionViol accounts for
    "All CA fields rootCA ca_fields L1 L2 L #t1 #t2.
        BrowserAcceptsChain(CA, fields, rootCA, ca_fields, L1, L2)@t1
        & ((L = L1) | (L = L2))
        & SCTAuditTransparencyCheck(L, fields)@t2
        & #t1 < #t2
            ==>
            SCTAuditTransparencyCheckSuccess(L, fields)@t2
    "
            /* then the monitor can find the certificate in the log too */

/* ======================================
       End2End Accountable Authenticity
   ====================================== */

/***** Accountable Authenticity (CT) *****/

lemma A_uniq1_helper [reuse]:
    "All CA M rootCA fields ca_fields #t1 #t2.
        Asserts( M, 'This CA has the following fields and it failed the SCT audit for the following fields.', CA, <fields, ca_fields>)@t1 
        & Asserts( rootCA, 'I signed this intermediate CA.', CA, ca_fields)@t2
        ==>
        (Ex #i. Corrupted( CA ) @ #i)
    "

lemma A_uniq2_helper [reuse]:
    "All rootCA CA ca_fields #t.
    Asserts('CCADB', 'No root CA signed this CA.', CA, <ca_fields,rootCA>)@t
    ==> (Ex #t. Corrupted(rootCA)@t)"


/***** Accountable Authenticity (CT + SCT Auditing) *****/


test ca_rogue_audit_mon_honest:
    "Ex M ca_fields fields rootCA #t #t0 #t1.
        SCTAuditCheck(M, fields, ca_fields)@t
        & Asserts(M, 'This CA has the following fields and it failed the SCT audit for the following fields.', CA, <fields, ca_fields>)@t0
        & Asserts(rootCA, 'I signed this intermediate CA.', CA, <ca_fields>)@t1
        & not (Ex #t. Corrupted(M)@t) "

test root_ca_rogue_audit_mon_honest:
    "Ex M ca_fields fields CA #t #t0 #t1. 
        SCTAuditCheck(M, fields, ca_fields)@t
        & Asserts(M, 'This CA has the following fields and it failed the SCT audit for the following fields.', CA, <fields, ca_fields>)@t0
        & Asserts('CCADB', 'No root CA signed this CA.', CA, <ca_fields,rootCA>)@t1 /* rootCA free */
        & not (Ex #t. Corrupted(M)@t)"
/*
CTAudit Scenario 1: Monitor receives a certificate via auditing (shared by some client) and checks authenticity on it. Then further distinguishes between the cases where the CA is documented or not (wrt the root CA) and blames accordingly (as before).
*/
lemma A_CTAudit_1:
    ca_rogue_audit_mon_honest, root_ca_rogue_audit_mon_honest accounts for
    "All CA fields rootCA ca_fields L1 L2 M #t0 #t1. 
        SCTAuditCheck(M, fields, ca_fields)@t0
        & BrowserAcceptsChain(CA, fields, rootCA, ca_fields, L1, L2)@t1
        // For every certificate that is audited to the monitor
        & not (Ex #t. Corrupted(M)@t)
            ==> 
                (Ex CA #t. GroundTruth(CA, fields)@t)"


test ca_rogue_audit:
 "Ex M ca_fields fields rootCA #t #t0 #t1.
  SCTAuditCheck(M, fields, ca_fields)@t
  & Asserts(M, 'This CA has the following fields and it failed the SCT audit for the following fields.', CA, <fields, ca_fields>)@t0
  & Asserts(rootCA, 'I signed this intermediate CA.', CA, <ca_fields>)@t1
 "

test root_ca_rogue_audit:
 "Ex M ca_fields fields CA #t #t0 #t1. 
  SCTAuditCheck(M, fields, ca_fields)@t
  & Asserts(M, 'This CA has the following fields and it failed the SCT audit for the following fields.', CA, <fields, ca_fields>)@t0
  & Asserts('CCADB', 'No root CA signed this CA.', CA, <ca_fields,rootCA>)@t1
 "

/* CTAudit Scenario 2: 

This version allows the monitor to sleep. It is a counterexample to the previous one. */
lemma A_CTAudit_2:
    ca_rogue_audit, root_ca_rogue_audit accounts for
    "All CA fields rootCA ca_fields L1 L2 M #t0 #t1. 
        SCTAuditCheck(M, fields, ca_fields)@t0
        & BrowserAcceptsChain(CA, fields, rootCA, ca_fields, L1, L2)@t1
            /* cert with fields is audited to monitor */
            ==> 
                (Ex CA #t. GroundTruth(CA, fields)@t)"

/* END LEMMAS */

// ===================================================================

#ifdef SUFFICIENCY_PROOF
/* These restrictions are intended to simplify sufficiency proofs for some of the accountability properties. There, we want to show the existence of some specific traces. Limiting the number of certain rules, we can speed up finding traces that fulfill our requirements for sufficiency. These restrictions should not be used in any other lemmas. */

restriction CA_Registr_once:
    "All rootCA1 #t1 rootCA2 #t2. Root_CA_Init(rootCA1)@t1 & Root_CA_Init(rootCA2)@t2 ==> (#t1 = #t2)"

restriction NonRoot_CA_Registr_once:
    "All CA1 #t1 CA2 #t2. NonRoot_CA_Init(CA1)@t1 & NonRoot_CA_Init(CA2)@t2 ==> (#t1 = #t2)"

restriction PreCertified_once:
    "All CA1 preC1 CA2 preC2 #t1 #t2. PreCertified(CA1, preC1)@t1 & PreCertified(CA2, preC2)@t2 ==> (#t1 = #t2)"

restriction Certified_once:
    "All CA1 fields1 fields2 CA2 #t1 #t2. CAAsserts(CA1, fields1)@t1 & CAAsserts(CA2, fields2)@t2 ==> (#t1 = #t2)"

restriction ChainAccept_once:
    "All L11 L21 rootCA1 ca_fields1 CA1 fields1 #t1 L12 L22 rootCA2 ca_fields2 CA2 fields2 #t2. BrowserAcceptsChain( CA1, fields1, rootCA1,ca_fields1, L11, L21 )@t1 & BrowserAcceptsChain( CA2, fields2, rootCA2, ca_fields2,  L12, L22 )@t2 ==> (#t1 = #t2)"

restriction addtolog_per_logger_once:
    "All L log_id1 chain1 log_id2 fields1 fields2 chain2 ca_cert1 ca_cert2 time1 time2 #t1 #t2. LoggerComputesAddLog(L, log_id1, fields1, ca_cert1, chain1, time1)@t1 & LoggerComputesAddLog(L, log_id2, fields2, ca_cert2, chain2, time2)@t2 ==> (#t1 = #t2)"

restriction time_once:
    "All i #t1 #t2. Time(i)@t1 & Time(i)@t2 ==> (#t1 = #t2)"

#endif

// ==============================================================================

end
